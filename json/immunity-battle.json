  "release": "Release #1",
  "committee": "Eastern 2 Scientific Committee",
  "sections": [
    {
      "section_title": "Immune System Overview",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["immunity battle", "immune system", "immune defense"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "list",
              "data": [
                "The immune system protects the human body from enemies attacks including infectious diseases (viruses, bacteria, fungi, parasites), allergens, and tumors."
              ]
            }
          ]
        },
        {
          "item_title": "Components",
          "keywords": ["immunity battle", "innate immunity", "adaptive immunity"],
          "blocks": [
            {
              "block_heading": "Innate Immunity",
              "block_type": "list",
              "data": [
                "Active from birth",
                "Consists of physical barriers (skin, gastrointestinal tract lining)",
                "Specialized immune cells that quickly attack pathogens",
                "Responds quickly leading to inflammation and fever",
                "Attacks broadly without recognizing specific pathogens"
              ]
            },
            {
              "block_heading": "Adaptive Immunity",
              "block_type": "list",
              "data": [
                "Learns from exposure to new germs",
                "Immune cells remember invaders for faster future response"
              ]
            }
          ]
        },
        {
          "item_title": "Key Players",
          "keywords": ["immunity battle", "leukocytes", "lymphatic system", "white blood cells", "phagocytes", "lymphocytes"],
          "blocks": [
            {
              "block_heading": "Leukocytes (White Blood Cells)",
              "block_type": "list",
              "data": [
                "Patrol blood and tissues searching for intruders",
                "Launch immune attacks when detecting foreign substances",
                "Types: Phagocytes (engulf pathogens) and Lymphocytes (B-cells and T-cells)"
              ]
            },
            {
              "block_heading": "Lymphatic System",
              "block_type": "list",
              "data": [
                "Network of lymph vessels that collect excess fluids",
                "Lymph nodes filter and trap harmful germs",
                "Swollen lymph nodes indicate active immune response"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Immune System Activation",
      "items": [
        {
          "item_title": "Process",
          "keywords": ["immunity battle", "antigens", "antibodies", "B-cells", "immune response", "pathogen defense", "adaptive immunity", "flu vaccination", "immune activation"],
          "blocks": [
            {
              "block_heading": "Process",
              "block_type": "list",
              "data": [
                "Antigens (microbes, toxins, chemicals) trigger immune response",
                "First exposure stores information about the germ",
                "Subsequent exposures trigger faster response via B-cells producing antibodies",
                "Antibodies attach to antigens signaling immune system to attack"
              ]
            },
            {
              "block_heading": "Challenges",
              "block_type": "list",
              "data": [
                "Some pathogens adapt and change over time (e.g., requiring annual flu shots)"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Immune Cell Types",
      "items": [
        {
          "item_title": "Mast Cell",
          "keywords": ["immunity battle", "immune cells", "mast cell", "histamine", "inflammation", "immune response"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Dilates blood vessels, induces inflammation through histamines and heparin, recruits macrophages and neutrophils"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Connective tissues, mucous membranes"
            }
          ]
        },
        {
          "item_title": "Macrophage",
          "keywords": ["immunity battle", "immune cells", "macrophage", "phagocyte", "pathogen clearance", "antigen presentation"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Phagocytic cell that consumes pathogens and cancer cells, stimulates other immune cells"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Migrates from blood vessels into tissues"
            }
          ]
        },
        {
          "item_title": "Natural Killer Cell",
          "keywords": ["immunity battle", "immune cells", "NK cell", "natural killer", "tumor surveillance", "viral defense"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Kills tumor cells and virus-infected cells"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Circulates in blood and migrates into tissues"
            }
          ]
        },
        {
          "item_title": "Dendritic Cell",
          "keywords": ["immunity battle", "immune cells", "dendritic cell", "antigen presentation", "adaptive immunity", "immune activation"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Presents antigens triggering adaptive immunity"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Epithelial tissue, migrates to lymph nodes when activated"
            }
          ]
        },
        {
          "item_title": "Monocyte",
          "keywords": ["immunity battle", "immune cells", "monocyte", "macrophage precursor", "inflammation response"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Differentiates into macrophages and dendritic cells in response to inflammation"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Stored in spleen, moves through blood to infected tissues"
            }
          ]
        },
        {
          "item_title": "Neutrophil",
          "keywords": ["immunity battle", "immune cells", "neutrophil", "first responder", "bacterial defense", "phagocytosis"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "First responders at infection sites (50-60% of leukocytes), releases toxins against bacteria/fungi"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Migrates from blood vessels into tissues"
            }
          ]
        },
        {
          "item_title": "Basophil",
          "keywords": ["immunity battle", "immune cells", "basophil", "histamine", "parasite defense", "allergic response"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Defends against parasites, releases inflammation-causing histamines"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Circulates in blood and migrates to tissues"
            }
          ]
        },
        {
          "item_title": "Eosinophil",
          "keywords": ["immunity battle", "immune cells", "eosinophil", "parasite defense", "allergic response", "tissue inflammation"],
          "blocks": [
            {
              "block_heading": "Characteristics",
              "block_type": "text",
              "data": "Releases toxins against bacteria/parasites (can cause tissue damage)"
            },
            {
              "block_heading": "Location",
              "block_type": "text",
              "data": "Circulates in blood and migrates to tissues"
            }
          ]
        }
      ]
    },
