              "block_heading": "Application Guidelines",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "SPF 15",
                  "children": ["Reapply after 1 hour, cream formula for dry skin"]
                },
                {
                  "parent": "SPF 30",
                  "children": ["Reapply after 2 hours, fluid-gel for oily skin"]
                },
                {
                  "parent": "SPF 50",
                  "children": ["Reapply after 4 hours, milk formula for body"]
                }
              ]
            }
          ]
        }
      ]
