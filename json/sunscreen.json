  "type": "condition-guide",
  "release": "Release #1",
  "committee": "WeCare committee",
  "sections": [
    {
      "section_title": "Solar Radiation",
      "items": [
        {
          "item_title": "Overview",
          "keywords": ["solar radiation", "sun energy", "electromagnetic radiation", "photosynthesis", "UV radiation", "IR radiation"],
          "blocks": [
            {
              "block_heading": "Overview",
              "block_type": "list",
              "data": [
                "Solar radiation is the energy emitted by the sun in the form of electromagnetic radiation. It is a mixture of visible light, ultraviolet (UV) radiation, infrared (IR) radiation, and radio waves.",
                "Essential for life on Earth as it provides energy for photosynthesis."
              ]
            }
          ]
        },
        {
          "item_title": "Types of Solar Radiation",
          "keywords": ["infrared rays", "visible light", "ultraviolet rays", "UVA", "UVB", "UVC", "ozone layer"],
          "blocks": [
            {
              "block_heading": "Infrared Rays (IR)",
              "block_type": "text",
              "data": "Longer wavelength than visible light, emit heat"
            },
            {
              "block_heading": "Visible Rays (VI)",
              "block_type": "text",
              "data": "Perceived by human eye as colors (red, orange, yellow, green, cyan, blue, violet)"
            },
            {
              "block_heading": "Ultraviolet (UV) Rays",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "General",
                  "children": ["Invisible to human eye, most serious impact on skin"]
                },
                {
                  "parent": "UVA",
                  "children": ["Passes through atmosphere easily, reaches surface, causes aging"]
                },
                {
                  "parent": "UVB",
                  "children": ["Partially blocked by atmosphere, causes sunburn and skin damage"]
                },
                {
                  "parent": "UVC",
                  "children": ["Completely absorbed by ozone layer"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Solar Radiation Effects on Skin",
      "items": [
        {
          "item_title": "Short-term Effects",
          "keywords": ["sunburn", "suntan", "wrinkles", "age spots", "collagen damage", "elastin damage", "short-term sun effects"],
          "blocks": [
            {
              "block_heading": "Short-term Effects",
              "block_type": "list",
              "data": [
                "Sunburn",
                "Suntan",
                "Wrinkles (breakdown of collagen and elastin)",
                "Age spots (solar lentigines)"
              ]
            }
          ]
        },
        {
          "item_title": "Long-term Effects",
          "keywords": ["skin cancer", "melanoma", "photo-aging", "immunosuppression", "long-term sun effects"],
          "blocks": [
            {
              "block_heading": "Long-term Effects",
              "block_type": "list",
              "data": [
                "Skin cancer",
                "Melanoma (most serious skin cancer)",
                "Photo-aging",
                "Immunosuppression"
              ]
            }
          ]
        },
        {
          "item_title": "UVR Action Table",
          "keywords": ["UVR action", "UVB effects", "UVA effects", "erythema", "melanin synthesis", "pigmentation"],
          "blocks": [
            {
              "block_heading": "UVB Effects",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Short-term",
                  "children": ["Erythema"]
                },
                {
                  "parent": "Long-term",
                  "children": ["Skin cancers"]
                }
              ]
            },
            {
              "block_heading": "UVA Effects",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Short-term",
                  "children": ["Melanin synthesis, immediate pigmentation"]
                },
                {
                  "parent": "Long-term",
                  "children": ["Immunosuppression, photo-aging"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "UVA vs UVB",
      "items": [
        {
          "item_title": "UVA Characteristics",
          "keywords": ["UVA", "longwave radiation", "natural tan", "photosensitivity", "skin aging", "DNA damage"],
          "blocks": [
            {
              "block_heading": "UVA Characteristics",
              "block_type": "list",
              "data": [
                "Longwave radiation (400-320 nm)",
                "Weak erythrogenic activity but penetrates dermis",
                "Responsible for slow natural tan",
                "Causes most drug-induced photosensitivity reactions",
                "May augment UVB effects",
                "Causes skin aging and DNA damage"
              ]
            }
          ]
        },
        {
          "item_title": "UVB Characteristics",
          "keywords": ["UVB", "middle wave radiation", "sunburn", "vitamin D synthesis", "skin cancer", "erythrogenic"],
          "blocks": [
            {
              "block_heading": "UVB Characteristics",
              "block_type": "list",
              "data": [
                "Middle wave radiation (320-290 nm)",
                "Highest erythrogenic activity",
                "Produces new pigment formation, sunburn, Vitamin D synthesis",
                "Responsible for inducing skin cancer",
                "Affects top skin layer",
                "Causes redness, burns, skin cancer"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Sunscreen Basics",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["sunscreen definition", "UV protection", "topical protection"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "text",
              "data": "Topical product that protects skin from harmful UV rays by absorbing, reflecting, or scattering them"
            }
          ]
        },
        {
          "item_title": "SPF (Sun Protection Factor)",
          "keywords": ["SPF", "sun protection factor", "UVB protection", "SPF 15", "SPF 30", "SPF 50"],
          "blocks": [
            {
              "block_heading": "SPF",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Measures protection against UVB rays"]
                },
                {
                  "parent": "Scale",
                  "children": [
                    "SPF 15: Blocks 93% of UVB",
                    "SPF 30: Blocks 97% of UVB",
                    "SPF 50: Blocks 98% of UVB"
                  ]
                },
                {
                  "parent": "Note",
                  "children": ["SPF 30 blocks half the radiation that SPF 15 would let through"]
                },
                {
                  "parent": "Recommendation",
                  "children": ["Most dermatologists recommend SPF 30 or higher"]
                }
              ]
            }
          ]
        },
        {
          "item_title": "Minimum Erythemal Dose (MED)",
          "keywords": ["minimum erythemal dose", "MED", "skin redness"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "text",
              "data": "Amount of UV energy required to produce first visible redness on skin"
            }
          ]
        }
      ]
    },
    {
