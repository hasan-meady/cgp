  "sections": [
    {
      "section_title": "Common Cold",
      "items": [
        {
          "item_title": "Common Cold",
          "keywords": ["Common Cold", "supportive care", "decongestants", "vitamin C", "zinc", "Echinacea", "pelargonium", "acetaminophen", "NSAIDs"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Common cold is an acute, generally viral infection of the upper respiratory tract, also known as acute nasopharyngitis, rhinosinusitis, or rhinopharyngitis."]
                },
                {
                  "parent": "Symptoms",
                  "children": ["Headache", "Sore throat", "Nasal congestion", "Runny nose", "Sneezing", "Cough"]
                },
                {
                  "parent": "Causes",
                  "children": ["Rhinoviruses (majority)", "Adenoviruses", "Coronaviruses", "Other viruses"]
                },
                {
                  "parent": "Seasonal Peaks",
                  "children": ["Rhinoviruses: Summer or fall", "Coronaviruses and influenza: Winter"]
                }
              ]
            },
            {
              "block_heading": "Red Flags",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Signals indicating a more significant problem requiring medical attention."]
                },
                {
                  "parent": "Signals",
                  "children": [
                    "Fever after initial days (double-worsening)",
                    "Altered mental status (e.g., loss of appetite, decreased consciousness)",
                    "Sore throat for more than 5 days",
                    "Headache or stiff neck (possible meningitis)",
                    "Sinus pain lasting more than 10-14 days after URI symptoms (possible bacterial sinus infection)"
                  ]
                }
              ]
            },
            {
              "block_heading": "Risk Factors",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Factors increasing susceptibility to the common cold."]
                },
                {
                  "parent": "Factors",
                  "children": [
                    "Exposure to someone with a cold",
                    "Smoking",
                    "Psychosocial stress",
                    "Insufficient sleep (<6 hours nightly)",
                    "International airline travel (20-30% report URI within 72 hours)"
                  ]
                }
              ]
            },
            {
              "block_heading": "Management",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Supportive care and symptomatic relief for the common cold."]
                },
                {
                  "parent": "Pharmacologic",
                  "children": [
                    "Antipyretics (e.g., NSAIDs, acetaminophen)",
                    "Nasal saline irrigation",
                    "Nasal or oral decongestants",
                    "Herbal medications (e.g., pelargonium)"
                  ]
                },
                {
                  "parent": "Non-Pharmacologic",
                  "children": [
                    "Rest and hydration",
                    "Vitamin C and Echinacea for immunity",
                    "Oral zinc acetate or lozenges to shorten symptom duration",
                    "Stress reduction",
                    "Adequate sleep"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Influenza",
      "items": [
        {
          "item_title": "Influenza",
          "keywords": ["influenza prevention", "vaccination", "INFLUAC TETRA"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Influenza is a viral infection caused by single-stranded, segmented RNA viruses, primarily types A and B, leading to seasonal epidemics."]
                },
                {
                  "parent": "Virus Types",
                  "children": ["Influenza A (H3N2, H1N1)", "Influenza B", "Influenza C (mild, non-epidemic)"]
                },
                {
                  "parent": "Symptoms",
                  "children": [
                    "Fever",
                    "Tiredness",
                    "Muscle aches",
                    "Runny nose",
                    "Sore throat",
                    "Vomiting",
                    "Diarrhea",
                    "Watery red eyes",
                    "Dry cough",
                    "Chills",
                    "Headache"
                  ]
                },
                {
                  "parent": "Transmission",
                  "children": ["Respiratory droplet"]
                },
                {
                  "parent": "Incubation Period",
                  "children": ["1-4 days"]
                }
              ]
            },
            {
              "block_heading": "Risk Factors",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Groups at higher risk for complicated or severe influenza."]
                },
                {
                  "parent": "Groups",
                  "children": [
                    "Persons >50 years old",
                    "Chronic pulmonary conditions (e.g., asthma)",
                    "Cardiovascular disorders",
                    "Metabolic disorders (e.g., diabetes mellitus)",
                    "Immunosuppression (e.g., HIV)",
                    "Pregnant women during influenza season",
                    "Obesity (BMI >40 kg/m²)"
                  ]
                }
              ]
            },
            {
              "block_heading": "Complications",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Major complications associated with influenza."]
                },
                {
                  "parent": "Complications",
                  "children": ["Primary influenza pneumonia", "Secondary bacterial pneumonia"]
                }
              ]
            },
            {
              "block_heading": "Management",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Supportive Care",
                  "children": ["Rest, hydration, and OTC medications for symptom relief"]
                },
                {
                  "parent": "Oseltamivir",
                  "children": ["Dosage: 75 mg orally twice daily for 5 days", "Use: High-risk patients"]
                },
                {
                  "parent": "Zanamivir",
                  "children": ["Dosage: 10 mg (2 inhalations of 5 mg) twice daily for 5 days", "Use: High-risk patients"]
                },
                {
                  "parent": "Note",
                  "children": ["Adamantanes (Amantadine, Rimantadine) are not used due to resistance."]
                }
              ]
            },
            {
              "block_heading": "Prevention",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Strategies to prevent influenza."]
                },
                {
                  "parent": "Methods",
                  "children": [
                    "Annual immunization for individuals ≥6 months without contraindications",
                    "Antiviral Prophylaxis: Oseltamivir or Zanamivir (same as therapy but once daily)"
                  ]
                },
                {
                  "parent": "Products",
                  "children": ["INFLUAC TETRA: Influenza vaccine for prevention"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Sinusitis",
      "items": [
        {
          "item_title": "Sinusitis",
          "keywords": ["sinusitis management", "nasal decongestant", "intranasal corticosteroids", "vitamin C", "zinc", "Echinacea", "propolis"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Acute rhinosinusitis or sinusitis refers to inflammation of the paranasal sinuses lasting 4 weeks or less."]
                },
                {
                  "parent": "Bacterial Causes",
                  "children": ["Most commonly Streptococcus pneumoniae (>50%)"]
                },
                {
                  "parent": "Viral Causes",
                  "children": ["Associated with upper respiratory infections"]
                },
                {
                  "parent": "Fungal Causes",
                  "children": ["Rare, life-threatening with high mortality"]
                },
                {
                  "parent": "Duration",
                  "children": ["Acute: ≤4 weeks", "Subacute: 4-12 weeks", "Chronic: ≥12 weeks", "Recurrent: ≥4 episodes/year"]
                }
              ]
            },
            {
              "block_heading": "Risk Factors",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Factors contributing to sinusitis."]
                },
                {
                  "parent": "Factors",
                  "children": ["Smoking", "Allergic rhinitis", "Anatomic abnormalities impairing drainage"]
                }
              ]
            },
            {
              "block_heading": "Symptoms (PODS)",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Key symptoms of sinusitis."]
                },
                {
                  "parent": "Symptoms",
                  "children": [
                    "Facial pain, pressure, or fullness",
                    "Nasal obstruction",
                    "Nasal purulence or discolored discharge (frontal or postnasal)",
                    "Smell disorders"
                  ]
                }
              ]
            },
            {
              "block_heading": "Management",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Treatment options for sinusitis."]
                },
                {
                  "parent": "Pharmacologic",
                  "children": [
                    "Topical decongestants (3-5 days to prevent rebound congestion)",
                    "Intranasal corticosteroids",
                    "Intranasal saline irrigation",
                    "Antihistamines (if allergic component present)"
                  ]
                },
                {
                  "parent": "Non-Pharmacologic",
                  "children": ["Smoking cessation", "Decongestants or nasal steroids for acute rhinosinusitis"]
                },
                {
                  "parent": "Prevention",
                  "children": [
                    "Hand washing",
                    "Influenza and pneumococcal vaccinations",
                    "Avoiding smoke",
                    "Reduction of environmental allergens",
                    "Masks",
                    "Immune-boosting supplements (e.g., Vitamin C, Zinc, Echinacea, Propolis)"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Snoring & Sleep Apnea",
      "items": [
        {
          "item_title": "Snoring & Sleep Apnea",
          "keywords": ["sleep apnea treatment", "Asonor Spray", "weight loss", "Philips Cpap Dorma 200", "Germany Hospital Equipments Cpap Ea", "Philips Dreamstation Cpap Auto A-Flex", "Hoffrichter Point 2 Auto-Cpap 5Cpi10", "Philips Respironics Cpap Auto", "Philips System One Epap Pro", "Philips System One Epap Auto", "St-20 Hospital Equipments Bipap"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Management options for snoring and sleep apnea."
            },
            {
              "block_heading": "Asonor Spray",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Lubricates and softens throat mucous membranes, tightens musculature to ease breathing."]
                },
                {
                  "parent": "Instructions",
                  "children": ["4-6 puffs in each nostril nightly for 2-4 weeks until solution is felt in throat."]
                }
              ]
            },
            {
              "block_heading": "Non-Pharmacologic",
              "block_type": "list",
              "data": ["Weight loss", "Smoking cessation", "Sleeping in lateral position"]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": [
                "No improvement with non-pharmacological or OTC treatments",
                "Symptoms of sleep apnea: excessive daytime sleepiness, observed stopped breathing, gasping/choking at night, dry mouth/sore throat in morning, morning headaches, trouble focusing, mood changes, high blood pressure"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Asthma",
      "items": [
        {
          "item_title": "Asthma",
          "keywords": ["asthma triggers", "salbutamol", "exercise", "asthma management", "ipratropium", "Seretide Diskus", "Spiriva HandiHaler", "Spiriva Respimat", "Atrovent HFA", "tiotropium", "ipratropium bromide"],
          "blocks": [
            {
              "block_heading": "Management",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Management of asthma exacerbations."]
                },
                {
                  "parent": "SABA (Short-acting β2-agonists)",
                  "children": ["Example: Salbutamol", "Use: Quick relief for asthma attacks"]
                },
                {
                  "parent": "Systematic Corticosteroid",
                  "children": ["Use: Short-term for acute exacerbations and severe asthma"]
                },
                {
                  "parent": "SAMA (Short-acting muscarinic antagonist)",
                  "children": ["Example: Ipratropium", "Use: Quick relief for asthma attacks"]
                },
                {
                  "parent": "Seretide Diskus",
                  "children": ["Description: Maintenance therapy for asthma", "Instructions: Rinse mouth after use to prevent candida infection"]
                },
                {
                  "parent": "Spiriva",
                  "children": ["Description: Long-acting muscarinic antagonist for maintenance therapy in asthma", "Instructions: Use once daily via HandiHaler or Respimat"]
                },
                {
                  "parent": "Non-Pharmacologic",
                  "children": [
                    "Stop trigger medications (e.g., NSAIDs)",
                    "Refer to physician for therapy evaluation",
                    "Ensure proper inhaler technique"
                  ]
                }
              ]
            },
            {
              "block_heading": "Non-Pharmacologic Advice",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Lifestyle and environmental adjustments to manage asthma."]
                },
                {
                  "parent": "Trigger Avoidance",
                  "children": [
                    "Respiratory infections",
                    "Indoor/outdoor allergens",
                    "Medications (e.g., beta-blockers, aspirin, NSAIDs)",
                    "Irritants (e.g., smoke, perfumes)"
                  ]
                },
                {
                  "parent": "Physical Activity",
                  "children": [
                    "Use salbutamol inhaler 5 minutes before exercise",
                    "Start exercise gradually",
                    "Warm up",
                    "Avoid outdoor exercise in extreme cold, cover mouth/nose with scarf"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
