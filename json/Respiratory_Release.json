                {
                  "parent": "Antipyretics & Painkillers",
                  "children": ["Examples: Paracetamol, Ibuprofen", "Use: Relieve fever and pain"]
                },
                {
                  "parent": "Bronchodilator Inhalation",
                  "children": ["Example: Ventolin (via nebulizer)", "Use: Relieve breathing difficulty"]
                },
                {
                  "parent": "Antiseptic Mouthwash/Gargle",
                  "children": ["Example: Avalon Povidone Iodine", "Use: Reduce throat irritation"]
                }
              ]
            },
            {
              "block_heading": "Supportive Care",
