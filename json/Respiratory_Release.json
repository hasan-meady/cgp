    {
      "section_title": "Case Studies",
      "items": [
        {
          "item_title": "Case 1 - Viral Tonsillitis",
          "keywords": ["viral tonsillitis", "ibuprofen", "paracetamol", "vitamin C", "zinc", "Manuka Honey", "Echinacea", "Sambune"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "6-year-old child with fever (37.8°C), painful swallowing, sore throat, and runny nose, likely viral tonsillitis."
            },
            {
              "block_heading": "Assessment Questions",
              "block_type": "list",
              "data": [
                "Severe difficulty swallowing or white pus-filled patches on tonsils? (Exclude bacterial tonsillitis)",
                "Recurrent symptoms or severe tonsillar hypertrophy causing sleep apnea? (Refer for tonsillectomy)"
              ]
            },
            {
              "block_heading": "Supportive Treatment",
              "block_type": "list",
              "data": ["OTC painkillers (ibuprofen, paracetamol)", "Rest and fluids", "Warm saltwater gargles", "OTC throat lozenges and sprays"]
            },
            {
              "block_heading": "Supplements",
              "block_type": "list",
              "data": ["Vitamin C", "Zinc", "Manuka Honey", "Echinacea", "Elderberry (Sambune)"]
            }
          ]
        },
        {
          "item_title": "Case 2 - Common Cold",
          "keywords": ["common cold", "decongestants", "vitamin C", "Echinacea", "zinc", "pelargonium", "acetaminophen", "NSAIDs"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "55-year-old male with runny nose, nasal congestion, sore throat, and headache post-flight, likely common cold."
            },
            {
              "block_heading": "Assessment Questions",
              "block_type": "list",
              "data": ["Neck stiffness, fever after initial days, or altered mental status? (Refer for significant issues)"]
            },
            {
              "block_heading": "Pharmacologic Management",
              "block_type": "list",
              "data": ["Antipyretics (NSAIDs, acetaminophen)", "Nasal saline irrigation", "Nasal/oral decongestants", "Herbal medications (pelargonium)"]
            },
            {
              "block_heading": "Non-Pharmacologic Management",
              "block_type": "list",
              "data": ["Rest and hydration", "Vitamin C and Echinacea", "Oral zinc acetate or lozenges", "Stress reduction", "Adequate sleep"]
            }
          ]
        },
        {
          "item_title": "Case 3 - Influenza",
          "keywords": ["influenza", "oseltamivir", "zanamivir", "INFLUAC TETRA"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "35-year-old with fever, chills, tiredness, headache, runny nose, watery eyes, dry cough, and muscle ache, likely influenza."
