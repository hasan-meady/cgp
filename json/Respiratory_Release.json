            {
              "block_heading": "Pharmacologic",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Expectorant Cough Syrup",
                  "children": ["Example: Ivyzac (ivy leaves dried extracts)", "Use: Soften mucus and ease elimination"]
