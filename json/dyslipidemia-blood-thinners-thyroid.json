    {
      "section_title": "Blood Thinners Medications",
      "items": [
        {
          "item_title": "Rivaroxaban",
          "associated_brands": ["xarelto"],
          "keywords": ["rivaroxaban", "xarelto", "blood thinner", "anticoagulant", "DOAC", "rivaroxaban brand names"],
          "blocks": [
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Doses ≥15 mg must be taken with food; doses ≤10 mg can be taken without regard to meals"]
            }
          ]
        },
        {
          "item_title": "Enoxaparin",
          "associated_brands": ["clexane"],
          "keywords": ["enoxaparin", "clexane", "LMWH", "heparin", "injection", "pregnancy", "enoxaparin brand names"],
          "blocks": [
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Subcutaneous injection, single use only"]
            },
            {
              "block_heading": "Instructions",
              "block_type": "list",
              "data": [
                "Do not rub injection site after administration to minimize bruising",
                "Do not expel air bubble from prefilled syringes (30 mg and 40 mg doses)",
                "Safe during pregnancy"
              ]
            }
          ]
        },
        {
          "item_title": "Warfarin",
          "associated_brands": ["coumadin"],
          "keywords": ["warfarin", "coumadin", "blood thinner", "vitamin K", "INR", "anticoagulant", "bleeding risk", "side effects of warfarin"],
          "blocks": [
            {
              "block_heading": "Drugs That Increase Effect",
              "block_type": "list",
              "data": ["Antibiotics: Metronidazole, TMP/SMX, Quinolones, Cephalosporins, Amoxicillin, Doxycycline", "Antifungals, Amiodarone increase bleeding risk"]
            },
            {
              "block_heading": "Drugs That Decrease Effect",
              "block_type": "list",
              "data": ["Rifampin, Phenytoin reduce effectiveness"]
            },
            {
              "block_heading": "Dietary Interactions",
              "block_type": "list",
              "data": ["Foods high in vitamin K decrease effectiveness"]
            },
            {
              "block_heading": "Herbals Supplements Interactions",
              "block_type": "list",
              "data": ["St. John's Wort reduces effect", "Garlic and cranberry increase bleeding risk (may lead to bruising/bleeding)"]
            },
            {
              "block_heading": "Foods to Avoid (High in Vitamin K)",
              "block_type": "list",
              "data": [
                "spinach [السبانخ]",
                "broccoli [البروكلي]",
                "kale [الكرنب الأجعد]",
                "brussels sprouts [كرنب بروكسل]",
                "green tea [الشاي الأخضر]",
                "parsley [البقدونس]",
                "cabbage [الملفوف]"
              ]
            }
          ]
        },
        {
          "item_title": "Aspirin",
          "keywords": ["aspirin", "antiplatelet", "bleeding risk", "GI effects", "heart protection", "side effects of aspirin"],
          "blocks": [
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Best taken at night with food or water to avoid GI effects", "Main job is working against heart attack and stroke"]
            },
            {
              "block_heading": "Increased Bleeding Risk Interactions",
              "block_type": "list",
              "data": ["Warfarin, Other anticoagulants"]
            },
            {
              "block_heading": "Reduced Efficacy Interactions",
              "block_type": "list",
              "data": ["ACE inhibitors, ARBs, Diuretics, Sulfonylureas decrease antihypertensive effect and increase hypoglycemia risk with sulfonylureas"]
            }
          ]
        },
        {
          "item_title": "Blood Thinners General Points",
          "keywords": ["bleeding risk", "drug interactions", "SSRIs", "SNRIs", "OTC", "NSAIDs", "PPIs", "clopidogrel"],
          "blocks": [
            {
              "block_heading": "General Points",
              "block_type": "list",
              "data": [
                "SSRIs (fluoxetine) or SNRIs (venlafaxine) increase bleeding risks when combined with antiplatelets/anticoagulants",
                "Check OTC medications (e.g., ibuprofen, naproxen) as they increase bleeding risks",
                "Garlic and ginger can enhance bleeding risks with antiplatelet/anticoagulant drugs",
                "Vitamin K-rich foods reduce warfarin effectiveness",
                "Cranberry may increase anticoagulant effect leading to bruising/bleeding",
                "PPI Interaction: Omeprazole and Esomeprazole may interact with Clopidogrel by reducing plasma level of activated Clopidogrel. Alternatives: Pantoprazole, Lansoprazole or Rabeprazole"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Thyroid Disorders Medications",
      "items": [
        {
          "item_title": "Levothyroxine",
          "associated_brands": ["euthyrox"],
          "keywords": ["levothyroxine", "euthyrox", "thyroid", "hypothyroidism", "T4", "thyroid hormone", "side effects of levothyroxine", "levothyroxine brand names"],
          "blocks": [
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": [
                "Morning: on empty stomach, 30-60 minutes before food",
                "Night: 3-4 hours after last meal"
              ]
            },
            {
              "block_heading": "Combinations with Folic Acid",
              "block_type": "list",
              "data": ["Mitigates cardiovascular risks from elevated homocysteine"]
            },
            {
              "block_heading": "Combinations with Coenzyme Q10",
              "block_type": "list",
              "data": ["Improves energy levels and alleviates fatigue/muscle weakness"]
            },
            {
              "block_heading": "Absorption Reducers Interactions",
              "block_type": "list",
              "data": ["PPIs, Sucralfate, Antacids cause hypochlorhydria reduces levothyroxine absorption"]
            },
            {
              "block_heading": "Protein Binding Displacers Interactions",
              "block_type": "list",
              "data": ["Carbamazepine (Tegretol), Furosemide, Heparin, Hydantoins, NSAIDs, Fenamates"]
            },
            {
              "block_heading": "Reduces Bioavailability",
              "block_type": "list",
              "data": ["Grapefruit juice reduces levothyroxine bioavailability"]
            },
            {
              "block_heading": "Special Considerations",
              "block_type": "list",
              "data": ["Addition of levothyroxine in diabetics may worsen glycemic control and require increased antidiabetic medication"]
            }
          ]
        }
      ]
    }
  ]
}