  "sections": [
    {
      "section_title": "Introduction to Hyperpigmentation",
      "items": [
        {
          "item_title": "What is Hyperpigmentation?",
          "keywords": ["hyperpigmentation", "skin care", "melanin", "skin lightening", "dermatology", "sun protection", "dark patches", "melanin excess", "skin discoloration"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Hyperpigmentation occurs when patches of skin become darker than surrounding areas due to excess melanin production."
            },
            {
              "block_heading": "Characteristics",
              "block_type": "list",
              "data": [
                "Affects all skin types",
                "Caused by excess melanin",
                "Appears as dark patches or spots"
              ]
            }
          ]
        },
        {
          "item_title": "Causes of Hyperpigmentation",
          "keywords": ["hyperpigmentation causes", "sun exposure", "hormonal changes", "medication effects", "sunspots", "age spots", "UV exposure", "melasma", "hormonal hyperpigmentation", "pregnancy skin changes", "post-inflammatory hyperpigmentation", "acne scars", "skin injury", "drug-induced hyperpigmentation", "photosensitivity", "medication side effects"],
          "blocks": [
            {
              "block_heading": "Sun Exposure",
              "block_type": "text",
              "data": "Prolonged sun exposure triggers melanin production, causing age spots or sunspots."
            },
            {
              "block_heading": "Hormonal Factors",
              "block_type": "text",
              "data": "Hormonal changes during pregnancy or contraceptive use can cause darker skin patches."
            },
            {
              "block_heading": "Physical Factors",
              "block_type": "text",
              "data": "Post-inflammatory hyperpigmentation occurs after skin injuries like cuts, burns, acne, or eczema."
            },
            {
              "block_heading": "Chemical Factors",
              "block_type": "text",
              "data": "Certain medications (e.g., antimalarials, retinoic acid, sulfonamides) cause drug-induced hyperpigmentation via photosensitive reactions."
            }
          ]
        }
      ]
    },
    {
      "section_title": "Skin Pigmentation Stages and Types",
      "items": [
        {
          "item_title": "Mechanism of Pigmentation",
          "keywords": ["melanin synthesis", "tyrosinase", "melanocytes", "keratinocytes"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "A complex process starting with melanin synthesis in melanocytes, involving tyrosinase, and transfer of melanosomes to keratinocytes."
            }
          ]
        },
        {
          "item_title": "Melasma",
          "keywords": ["melasma", "pregnancy hyperpigmentation", "facial dark patches"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Common in pregnant women or those on birth control, appearing on the forehead, face, and stomach."
            }
          ]
        },
        {
          "item_title": "Post-Inflammatory Hyperpigmentation",
          "keywords": ["post-inflammatory hyperpigmentation", "acne scars", "dark spots"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Dark spots or patches after inflammatory conditions like acne, eczema, burns, or surgeries."
            }
          ]
        },
        {
          "item_title": "Sunspots",
          "keywords": ["sunspots", "age spots", "solar lentigines"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Brown, tan, or black spots on sun-exposed areas, common in older adults or those with extended sun exposure."
            }
          ]
        }
      ]
    },
