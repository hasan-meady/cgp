              "data": ["600-800 IU/day"]
            },
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Taken with meals for better absorption (fat-soluble)"]
            }
          ]
        },
        {
          "item_title": "Zinc",
          "keywords": ["zinc", "immune support", "antiviral"],
          "blocks": [
            {
              "block_heading": "Adult Dosage",
