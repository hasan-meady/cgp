    {
      "section_title": "Cough Management",
      "items": [
        {
          "item_title": "Cough Management",
          "keywords": ["vitamin c", "ivyzac", "ivy leaves extract", "manuka honey", "acid blockers", "cough management", "gerd"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Use nebulizer, Vitamin C, avoid irritants (smoke, perfumes, dust)",
                "After Ivyzac (Ivy Leaves Ext.), drink water to thin mucus",
                "Manuka honey boosts immunity (avoid for children <1 year)",
                "For GERD-induced cough: use acid blockers"
              ]
            },
            {
              "block_heading": "Warnings",
              "block_type": "list",
              "data": ["Avoid honey for children less than 1 year"]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Asthma Management",
      "items": [
        {
          "item_title": "Asthma Management",
          "keywords": ["beta blockers", "arbs", "nsaids", "paracetamol", "montelukast", "corticosteroids", "bromhexine", "ambroxol", "ivy leaves syrup", "potassium supplements", "hypokalemia"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Beta blockers may limit airflow - prefer ARBs",
                "NSAIDs can exacerbate asthma - use paracetamol",
                "Montelukast granules: administer directly or with soft food (use within 15 min of opening sachets)",
                "Corticosteroid spray users: rinse mouth or use nebulizer to prevent oral infection",
                "Bromhexine not recommended for gastric ulcer patients - use Ambroxol or Ivy Leaves syrup",
                "Corticosteroids may cause hypokalemia - consider potassium supplements or potassium-rich foods (avocados, apples, oranges, bananas)"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Allergic Rhinitis",
      "items": [
        {
          "item_title": "Allergic Rhinitis",
          "associated_brands": ["Budinid", "Claritine", "Zyrtic", "Artiz"],
          "keywords": ["budesonide", "budinid", "loratadine", "claritine", "cetirizine", "zyrtic", "artiz", "antihistamines"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Budesonide (Budinid spray): only intranasal corticosteroid approved for pregnancy",
                "Loratadine (Claritine): safe in pregnancy",
                "Cetirizine (Zyrtic, Artiz): safe during lactation",
                "Second-generation oral antihistamines preferred - treat most symptoms except nasal congestion",
                "Intranasal corticosteroids treat all symptoms, safe for chronic use"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Moisturizers & Eczema",
      "items": [
        {
          "item_title": "Eczema Care",
          "keywords": ["eczema", "moisturizers", "tacrolimus", "pimecrolimus", "clobetasol propionate", "trigger foods", "skin care", "skin thinning"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Moisturize for patients on diuretics, antihistamines, isotretinoin, or menopausal women",
                "Use gentle cleansers, lukewarm water, sunscreen, fragrance-free moisturizers",
                "Stay hydrated, avoid excess caffeine, soaps, hot water, alcohol-based products, sun/wind",
                "Oral omega-3, hyaluronic acid, collagen for dryness",
                "Scratching worsens eczema; manage by moisturizing, using anti-itch creams, corticosteroids and cold compress",
                "Avoid trigger foods (dairy, eggs, nuts, soy, spices, chocolate, gluten)",
                "Apply Tacrolimus, Pimecrolimus twice daily - continue 7 days post-symptoms",
                "Clobetasol propionate: Do not exceed 2 weeks to avoid skin thinning",
                "Eczema routine: Clean, Moisturize, Treat, Avoid, Hydrate"
              ]
            }
          ]
        }
      ]
    }
  ]
