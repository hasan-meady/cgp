{
  "id": "pain-management",
  "title": "Pain Management Pharmaceutical Care",
  "type": "condition-guide",
  "release": "Release #1",
  "committee": "Eastern 2 Scientific Committee",
  "sections": [
    {
      "section_title": "Pain Management Highlights",
      "items": [
        {
          "item_title": "Paracetamol",
          "keywords": ["paracetamol", "carbamazepine", "liver damage", "hepatic impairment", "renal impairment"],
          "blocks": [
            {
              "block_heading": "Key Points",
              "block_type": "list",
              "data": [
                "No dose adjustment for renal impairment",
                "In cases of mild hepatic impairment, the maximum dose is 2000 mg/day",
                "With carbamazepine: reduces the effect of paracetamol and increases liver damage risk"
              ]
            }
          ]
        },
        {
          "item_title": "NSAIDs",
          "associated_brands": ["Brufen"],
          "keywords": ["cox-2 inhibitors", "naproxen", "nsaids", "ibuprofen", "brufen", "aspirin", "pregnancy", "breastfeeding", "cardiovascular risk"],
          "blocks": [
            {
              "block_heading": "Key Points",
              "block_type": "list",
              "data": [
                "Selective COX-2 inhibitors: lower GI ulceration but high cardiovascular risk",
                "Naproxen has least cardiovascular risk (max 1000 mg chronic, 1500 mg acute)",
                "Contraindicated during the third trimester of pregnancy",
                "Ibuprofen (Brufen) preferred in breastfeeding - minimal milk secretion",
                "Ibuprofen should be administered two hours after aspirin or at least eight hours before"
              ]
            }
          ]
        },
        {
          "item_title": "Supplements and Warnings",
          "keywords": ["vitamin b2", "magnesium", "vitamin d", "coq10", "curcumin", "headache", "migraine", "abdominal pain", "appendicitis", "osteoarthritis", "statin-induced myalgia", "hyperoxaluria"],
          "blocks": [
            {
              "block_heading": "Key Points",
              "block_type": "list",
              "data": [
                "Vitamin B2, magnesium, vitamin D, CoQ10 may help headaches/migraines",
                "Turmeric (curcumin) aids osteoarthritis",
                "CoQ10 eases statin-induced myalgia"
              ]
            },
            {
              "block_heading": "Warnings",
              "block_type": "list",
              "data": [
                "Avoid analgesics in lower right abdominal pain unless appendicitis excluded",
                "Large doses of vitamin C may cause hyperoxaluria"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Common Analgesics",
      "items": [
        {
          "item_title": "Paracetamol",
          "keywords": ["paracetamol", "pain relief", "analgesic"],
          "blocks": [
            {
              "block_heading": "Adult Dosage",
              "block_type": "list",
              "data": ["325-1000 mg every 6-8 hrs, max 4000 mg/day"]
            },
            {
              "block_heading": "Pediatric Dosage",
              "block_type": "list",
              "data": ["10-15 mg/kg every 4-6 hrs, max 5 doses/day"]
            },
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["No food requirements"]
            }
          ]
        },
        {
          "item_title": "Ibuprofen",
          "associated_brands": ["Brufen", "Nurofen"],
          "keywords": ["ibuprofen", "brufen", "nsaid", "nurofen"],
          "blocks": [
            {
              "block_heading": "Adult Dosage",
              "block_type": "list",
              "data": ["400 mg every 8 hrs or 600 mg every 12 hrs, max 1200 mg/day OTC, 3200 mg/day prescribed"]
            },
            {
              "block_heading": "Pediatric Dosage",
              "block_type": "list",
              "data": ["20 mg/kg body weight/day in divided doses"]
            },
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Take with food"]
            }
          ]
        },
        {
          "item_title": "Diclofenac",
          "associated_brands": ["Rofenac", "Rapidus"],
          "keywords": ["diclofenac", "nsaid", "rofenac", "rapidus"],
          "blocks": [
            {
              "block_heading": "Adult Dosage",
              "block_type": "list",
              "data": ["50 mg every 8-12 hrs, max 150 mg/day"]
            },
            {
              "block_heading": "Pediatric Dosage",
              "block_type": "list",
              "data": ["1-2 mg/kg body weight per day divided into 2 or 3 doses"]
            },
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": ["Take after food"]
            },
            {
              "block_heading": "Warnings",
              "block_type": "list",
              "data": ["Avoid in asthma"]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Supplements and Support",
      "items": [
        {
          "item_title": "Omega-3",
          "keywords": ["omega-3", "immune support", "anti-inflammatory"],
          "blocks": [
            {
              "block_heading": "Benefits",
              "block_type": "list",
              "data": [
                "Stimulates immune response",
                "Enhances absorption of fat-soluble vitamins (K, E, D, A)"
              ]
            }
          ]
        },
        {
          "item_title": "Probiotics",
          "keywords": ["probiotics", "gut health", "immune support"],
          "blocks": [
            {
              "block_heading": "Usage",
              "block_type": "list",
              "data": ["With broad-spectrum antibiotics to prevent antibiotic-associated diarrhea"]
            },
            {
              "block_heading": "Duration",
              "block_type": "list",
              "data": ["Taken concurrently and for one week after"]
            }
          ]
        },
        {
          "item_title": "Vitamin C",
          "keywords": ["vitamin c", "immune support", "antioxidant", "hyperoxaluria"],
          "blocks": [
            {
              "block_heading": "Benefits",
              "block_type": "list",
              "data": [
                "Boosts immunity",
                "Reduces oxidative stress"
              ]
            },
            {
              "block_heading": "Dosage",
              "block_type": "list",
              "data": ["1-2 g daily for 1-2 weeks to avoid hyperoxaluria"]
            },
            {
              "block_heading": "Warnings",
