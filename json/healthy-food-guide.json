      "section_title": "Why Healthy Food?",
      "items": [
        {
          "item_title": "Benefits of Healthy Food",
          "keywords": ["healthy food benefits", "nutrition", "disease prevention", "weight management", "skin health", "muscle growth", "immune support", "bone health", "digestion"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Healthy food supports overall well-being and prevents chronic diseases."
            },
            {
              "block_heading": "Benefits",
              "block_type": "list",
              "data": [
                "Keeps healthy skin",
                "Promotes healthy muscle growth",
                "Supports immunity",
                "Strengthens bones",
                "Aids digestive system",
                "Maintains healthy weight",
                "Lowers risk of chronic diseases"
              ]
            },
            {
              "block_heading": "Quote",
              "block_type": "text",
              "data": "You have to listen to your body. Take care of your inside body like outside."
            }
          ]
        }
      ]
    },
    {
      "section_title": "What is Healthy Food?",
      "items": [
        {
          "item_title": "Definition of Healthy Food",
          "keywords": ["healthy food definition", "nutrient-dense", "no added sugar", "lean protein", "minimally processed", "healthy fats", "non-starchy carbs"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Healthy food is minimally processed, nutrient-dense, and supports immunity and energy for good health."
            },
            {
              "block_heading": "Characteristics",
              "block_type": "list",
              "data": [
                "Not processed",
                "No sugar added",
                "No salt added",
                "Contains lean protein",
                "Includes non-starchy carbohydrates",
                "Contains healthy fats",
                "Nutrient-dense"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Understanding Sugar Content in Food",
      "items": [
        {
          "item_title": "Added vs. No Added Sugar",
          "keywords": ["sugar content", "added sugar", "no added sugar", "food labeling", "natural sugars", "empty calories"],
          "blocks": [
            {
              "block_heading": "Difference Between Added and No Added Sugar",
              "block_type": "text",
              "data": "Added sugar refers to sugars and syrups artificially incorporated during processing, providing empty calories. No added sugar means only naturally occurring sugars from fruits, dairy, or grains are present."
            },
            {
              "block_heading": "Health Impact",
              "block_type": "list",
              "data": [
                "Added sugars contribute to obesity, diabetes, and metabolic disorders",
                "No added sugar products are better but require moderation"
              ]
            }
          ]
        },
        {
          "item_title": "Common Food Labeling Terms",
          "keywords": ["food labeling", "sugar-free", "natural sweeteners", "low sugar", "artificial sweeteners", "diabetic-friendly"],
          "blocks": [
            {
              "block_heading": "Sugar-Free",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Definition",
                  "children": ["Contains less than 0.5 g sugar per serving"]
                },
                {
                  "parent": "Health Impact",
                  "children": ["Suitable for diabetics and weight-conscious individuals"]
                }
              ]
            },
            {
              "block_heading": "No Added Sugar",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Definition",
                  "children": ["No sugar added during processing, but may contain natural sugars"]
                },
                {
                  "parent": "Health Impact",
                  "children": ["Better than processed sugar but still needs moderation"]
                }
              ]
            },
            {
              "block_heading": "Low Sugar",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Definition",
                  "children": ["Contains less than 5 g of sugar per serving"]
                },
                {
                  "parent": "Health Impact",
                  "children": ["Good for maintaining stable blood sugar levels"]
                }
              ]
            },
            {
              "block_heading": "Artificial Sweeteners",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Definition",
                  "children": ["Synthetic sugar substitutes like aspartame and sucralose"]
                },
                {
                  "parent": "Health Impact",
                  "children": ["May have digestive side effects in some individuals"]
                }
              ]
            },
            {
              "block_heading": "Natural Sweeteners",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Definition",
                  "children": ["Derived from natural sources like stevia or monk fruit"]
                },
                {
                  "parent": "Health Impact",
                  "children": ["Lower glycemic impact, suitable for diabetics"]
                }
              ]
            }
          ]
        }
      ]
    },
