    {
      "section_title": "The Importance of Healthy Food",
      "items": [
        {
          "item_title": "Key Benefits",
          "keywords": ["healthy diet benefits", "disease prevention", "mental health", "gut health", "balanced diet", "immune health", "longevity"],
          "blocks": [
            {
              "block_heading": "Disease Prevention",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["A diet rich in fruits, vegetables, lean proteins, whole grains, and healthy fats lowers the risk of chronic diseases like heart disease and stroke."]
                },
                {
                  "parent": "Reference",
                  "children": ["Willett et al., 1995"]
                }
              ]
            },
            {
              "block_heading": "Weight Management",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Healthy food promotes portion control and balanced macronutrient intake, increasing satiety and reducing calorie consumption."]
                },
                {
                  "parent": "Reference",
                  "children": ["Rolls, 2009"]
                }
              ]
            },
            {
              "block_heading": "Mental Health and Cognitive Function",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Nutrients like omega-3 fatty acids, antioxidants, and B vitamins improve brain function and reduce the risk of neurodegenerative diseases."]
                },
                {
                  "parent": "Reference",
                  "children": ["Jacka et al., 2010"]
                }
              ]
            },
            {
              "block_heading": "Gut Health and Digestion",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Fiber-rich foods, probiotics, and prebiotics promote a healthy gut microbiome, essential for digestion and immunity."]
                },
                {
                  "parent": "Reference",
                  "children": ["Makki et al., 2018"]
                }
              ]
            },
            {
              "block_heading": "Longevity and Quality of Life",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Whole, plant-based foods, low sugar intake, and regular physical activity contribute to increased life expectancy."]
                },
                {
                  "parent": "Reference",
                  "children": ["Buettner, 2005"]
                }
              ]
            }
          ]
        }
      ]
    },
