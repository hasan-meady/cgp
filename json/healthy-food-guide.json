    {
      "section_title": "Diabetes-Friendly Foods",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["diabetes-friendly", "diabetes management", "low-carb foods", "high-fiber"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Diabetes-friendly foods are low in sugar and carbohydrates, with a low glycemic index to manage blood glucose levels. They emphasize high fiber, lean proteins, and healthy fats."
            },
            {
              "block_heading": "Goals",
              "block_type": "list",
              "data": [
                "Maintain balanced blood sugar levels",
                "Prevent diabetes complications"
              ]
            }
          ]
        },
        {
          "item_title": "Glycemic Index Explanation",
          "keywords": ["glycemic index", "blood sugar spikes", "slow-release carbs"],
          "blocks": [
            {
              "block_heading": "Glycemic Index",
              "block_type": "text",
              "data": "Carbohydrates that break down quickly have a high glycemic index (e.g., baked potato), releasing glucose rapidly. Slow-breaking carbs (e.g., oats) have a low glycemic index, releasing glucose gradually."
            }
          ]
        }
      ]
    },
