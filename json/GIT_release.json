{
  "id": "cgp-git-disorders",
  "title": "CGP GIT Disorders Guide",
  "type": "git-disorders-guide",
  "release": "Release #1",
  "committee": "Data Collection & Revision Team",
  "sections": [
    {
      "section_title": "Gastroesophageal Reflux Disease (GERD)",
      "items": [
        {
          "item_title": "GERD",
          "keywords": ["GERD", "heartburn", "regurgitation", "hiatal hernia"],
          "blocks": [
            {
              "block_heading": "Definition",
              "block_type": "text",
              "data": "GERD is the retrograde flow of stomach contents into the esophagus, which may be erosive or non-erosive."
            },
            {
              "block_heading": "Common Symptoms",
              "block_type": "list",
              "data": ["Heartburn", "Bad breath", "Dry cough", "Regurgitation"]
            },
            {
              "block_heading": "Alarm Symptoms",
              "block_type": "list",
              "data": ["Dysphagia", "Odynophagia", "Weight loss", "Chest pain", "Bleeding"]
            },
            {
              "block_heading": "Causes and Risk Factors",
              "block_type": "text",
              "data": "A key cause is hiatal hernia, where the upper stomach bulges through the diaphragm."
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Recommendations",
                  "children": [
                    "Minimize caffeine intake",
                    "Quit smoking",
                    "Lose weight",
                    "Wear loose clothing",
                    "Avoid lying down after meals",
                    "Sleep with head and shoulders propped up",
                    "Avoid fatty, fried foods, hot sauce, garlic, and onion"
                  ]
                },
                {
                  "parent": "Supplements",
                  "children": ["Manuka honey", "Probiotics (e.g., Enterogermina)"]
                }
              ]
            }
          ]
        },
        {
          "item_title": "Proton Pump Inhibitors (PPIs)",
          "associated_brands": ["Omiz", "Gasec", "Hyposec", "Gastrazole", "Nexium", "Esomep", "Esopole", "Peptazole", "Lanzor", "Pantazol", "Pantoloc", "Pantomax", "Toprazole", "Dexilant", "Pariet"],
          "keywords": ["PPI", "proton pump inhibitors", "acid suppression", "Omiz", "Gasec", "Hyposec", "Gastrazole", "Nexium", "Esomep", "Esopole", "Peptazole", "Lanzor", "Pantazol", "Pantoloc", "Pantomax", "Toprazole", "Dexilant", "Pariet"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "First-line treatment, blocks proton pump to inhibit H+/K+-ATPase enzyme."
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "One or two times daily, 30 minutes before meals (4 weeks for non-erosive, 8 weeks for erosive)."
            },
            {
              "block_heading": "Products",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Omeprazole",
                  "children": ["Brands: Omiz, Gasec, Hyposec, Gastrazole", "Notes: Category C in pregnancy, contraindicated with Clopidogrel"]
                },
                {
                  "parent": "Esomeprazole",
                  "children": ["Brands: Nexium, Esomep, Esopole"]
                },
                {
                  "parent": "Lansoprazole",
                  "children": ["Brands: Peptazole, Lanzor"]
                },
                {
                  "parent": "Pantoprazole",
                  "children": ["Brands: Pantazol, Pantoloc, Pantomax, Toprazole", "Notes: Less interaction with Clopidogrel"]
                },
                {
                  "parent": "Dexlansoprazole",
                  "children": ["Brands: Dexilant", "Notes: Can be taken with or without food"]
                },
                {
                  "parent": "Rabeprazole",
                  "children": ["Brands: Pariet"]
                }
              ]
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Calcium and magnesium deficiency", "Vitamin B12 deficiency", "Iron malabsorption"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "list",
              "data": [
                "Advise calcium, magnesium, B12, and iron supplements for long-term use",
                "Avoid with antiviral drugs to prevent loss of virologic control",
                "Replace with H2 blockers when used with IV methotrexate"
              ]
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Category B (except Omeprazole, Category C), safe under physician advice"
            }
          ]
        },
        {
          "item_title": "H2 Blockers",
          "associated_brands": ["Fixit 150", "Famoclar", "Famodar 20"],
          "keywords": ["H2 blockers", "Fixit", "acid secretion inhibition", "Famoclar", "Famodar"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Second-line or add-on therapy, less effective than PPIs."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Nizatidine (Fixit 150)", "Famotidine (Famoclar, Famodar 20)"]
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "Usually twice daily, not concomitant with PPIs or antacids."
            }
          ]
        },
        {
          "item_title": "Antacids",
          "associated_brands": ["Tums", "Gaviscon"],
          "keywords": ["antacids", "heartburn relief", "Tums", "Gaviscon"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Neutralize gastric acid for heartburn relief."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Calcium carbonate (e.g., Tums)", "Aluminum hydroxide/magnesium carbonate (e.g., Gaviscon)"]
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "After meals and before bed."
            }
          ]
        }
      ]
    },
    {
      "section_title": "Nausea and Vomiting",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["nausea causes", "vomiting symptoms"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Nausea and vomiting are symptoms of conditions like food poisoning, motion sickness, pregnancy, or migraines."
            }
          ]
        },
        {
          "item_title": "Non-Pharmacological Treatment",
          "keywords": ["dietary adjustments", "hydration"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Drink clear or ice-cold drinks",
                "Eat light, bland foods (e.g., saltine crackers, plain bread)",
                "Avoid fried, greasy, or sweet foods",
                "Eat slowly, in smaller, frequent meals",
                "Avoid mixing hot and cold foods",
                "Drink beverages slowly",
                "Avoid activity after eating"
              ]
            }
          ]
        },
        {
          "item_title": "Oral Electrolytes",
          "associated_brands": ["Bablyte", "Electrorush"],
          "keywords": ["oral rehydration", "electrolytes", "Bablyte", "Electrorush"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Prevent dehydration due to vomiting."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Bablyte", "Electrorush", "ORS sachets"]
            }
          ]
        },
        {
          "item_title": "Ondansetron",
          "associated_brands": ["Kromafina", "Zoron", "Zofran"],
          "keywords": ["ondansetron", "anti-emetic", "Kromafina", "Zoron", "Zofran"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Selective 5-HT3 serotonin-receptor antagonist."
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "Adults: 4-8 mg 2-4 times daily; Pediatrics: 0.1-0.2 mg/kg/dose 3-4 times"
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Headache", "Constipation", "QT prolongation"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Use cautiously in hepatic impairment or with QT prolongation risk."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Considered for severe vomiting in pregnancy if other agents fail."
            }
          ]
        },
        {
          "item_title": "Metoclopramide",
          "associated_brands": ["Primperan"],
          "keywords": ["metoclopramide", "gastric motility", "Primperan"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Antagonizes D2 receptors to improve gastric emptying."
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "10-15 mg orally 4 times daily, 30 minutes before meals/bed."
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Restlessness", "Dystonia", "Fatigue", "Hyperprolactinemia", "Tardive dyskinesia (rare)"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Use lowest dose for shortest duration due to tardive dyskinesia risk."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Generally safe at lowest dose."
            }
          ]
        },
        {
          "item_title": "Domperidone",
          "associated_brands": ["Dompy", "Motilium"],
          "keywords": ["domperidone", "nausea treatment", "Dompy", "Motilium"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Peripheral dopamine-2 receptor antagonist, enhances gastric motility."
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "10 mg orally 3-4 times daily, 30 minutes before meals/bed."
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Headache", "Abdominal cramps", "Diarrhea"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Caution in severe cardiac disease or with CYP3A4 inhibitors."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Use with caution due to insufficient data."
            }
          ]
        },
        {
          "item_title": "Referral Criteria",
          "keywords": ["emergency referral", "dehydration signs"],
          "blocks": [
            {
              "block_heading": "Symptoms Requiring Referral",
              "block_type": "list",
              "data": [
                "Vomiting blood (coffee grounds appearance)",
                "Severe headache or stiff neck",
                "Severe abdominal pain",
                "Fever over 38.3°C",
                "Vomiting with diarrhea",
                "Rapid breathing or pulse",
                "Lethargy, confusion, or decreased alertness",
                "Signs of dehydration (extreme thirst, dizziness, fatigue, palpitations)"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Peptic Ulcer",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["peptic ulcer types", "stomach sores"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Peptic ulcers are open sores on the stomach lining (gastric ulcers) or upper small intestine (duodenal ulcers)."
            }
          ]
        },
        {
          "item_title": "Symptoms",
          "keywords": ["ulcer symptoms", "melena"],
          "blocks": [
            {
              "block_heading": "Duodenal Ulcers",
              "block_type": "list",
              "data": ["Pain relieved by meals", "Occurs 2-3 hours after meals", "Most common type", "Dark, tarry stools (melena)"]
            },
            {
              "block_heading": "Gastric Ulcers",
              "block_type": "list",
              "data": ["Pain increased by meals", "Occurs 30 minutes to 1 hour after meals", "Less common", "Vomiting"]
            }
          ]
        },
        {
          "item_title": "Causes",
          "keywords": ["H. pylori", "NSAIDs"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Primarily caused by Helicobacter pylori infection or long-term NSAID use. Stress and spicy foods worsen symptoms but do not cause ulcers."
            }
          ]
        },
        {
          "item_title": "Referral Criteria",
          "keywords": ["ulcer complications", "emergency referral"],
          "blocks": [
            {
              "block_heading": "Symptoms Requiring Referral",
              "block_type": "list",
              "data": [
                "Vomiting or vomiting blood",
                "Dark blood in stools or black/tarry stools",
                "Trouble breathing",
                "Feeling faint",
                "Nausea or vomiting",
                "Unexplained weight loss",
                "Appetite changes"
              ]
            }
          ]
        },
        {
          "item_title": "Complications",
          "keywords": ["ulcer complications", "gastric cancer"],
          "blocks": [
            {
              "block_heading": "Complications",
              "block_type": "list",
              "data": ["Bleeding", "Perforation", "Obstruction", "Cancer"]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Helicobacter Pylori Infection",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["H. pylori infection", "chronic infection"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "H. pylori is a common, often chronic bacterial infection of the gastrointestinal tract, with possible hereditary susceptibility."
            }
          ]
        },
        {
          "item_title": "Transmission",
          "keywords": ["H. pylori transmission", "urease enzyme"],
          "blocks": [
            {
              "block_heading": "Transmission Routes",
              "block_type": "list",
              "data": ["Vertical (mother to child)", "Horizontal (across individuals or environmental contamination)"]
            },
            {
              "block_heading": "Mechanism",
              "block_type": "text",
              "data": "Urease enzyme generates ammonium ions to survive gastric acid."
            }
          ]
        },
        {
          "item_title": "Symptoms",
          "keywords": ["H. pylori symptoms", "gastrointestinal symptoms"],
          "blocks": [
            {
              "block_heading": "Common Symptoms",
              "block_type": "list",
              "data": ["Nausea", "Vomiting", "Heartburn", "Burping", "Stomach pain"]
            },
            {
              "block_heading": "Uncommon Symptoms",
              "block_type": "list",
              "data": ["Fatigue", "Anemia", "Diarrhea", "Dark stools", "Bad breath", "Loss of appetite", "Unintentional weight loss", "Skin rashes", "Unexplained hives", "Itchy skin"]
            }
          ]
        },
        {
          "item_title": "Risk Factors",
          "blocks": [
            {
              "block_heading": "Risk Factors",
              "block_type": "list",
              "data": [
                "Infected family members",
                "Crowded living conditions",
                "Poor hygiene",
                "Poor sanitation",
                "Having two or more siblings",
                "Fecal contamination of water supply",
                "Healthcare professionals"
              ]
            }
          ]
        },
        {
          "item_title": "Complications",
          "blocks": [
            {
              "block_heading": "Complications",
              "block_type": "list",
              "data": ["Gastritis", "Peptic ulcers", "Stomach cancer"]
            }
          ]
        },
        {
          "item_title": "Prevention",
          "blocks": [
            {
              "block_heading": "Prevention",
              "block_type": "list",
              "data": ["Good hygiene", "Hand washing", "Healthy nutrition", "Vaccine (preclinical)"]
            }
          ]
        },
        {
          "item_title": "Pharmacological Treatment",
          "keywords": ["H pylori treatment", "triple therapy", "bismuth quadruple"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Treatment depends on macrolide resistance and bismuth availability."
            },
            {
              "block_heading": "Macrolide Resistance <15%",
              "block_type": "list",
              "data": [
                "Clarithromycin-based triple therapy",
                "Bismuth quadruple therapy",
                "Sitafloxacin & vonoprazan-based triple therapy",
                "Rifabutin-based triple therapy"
              ]
            },
            {
              "block_heading": "Macrolide Resistance >15%",
              "block_type": "list",
              "data": [
                "Bismuth quadruple therapy",
                "Levofloxacin-based triple therapy",
                "Rifabutin-based triple therapy",
                "Susceptibility-guided therapy"
              ]
            },
            {
              "block_heading": "Bismuth-Unavailable Region",
              "block_type": "list",
              "data": [
                "Clarithromycin-based triple therapy",
                "Levofloxacin-based triple therapy",
                "Rifabutin-based triple therapy",
                "Susceptibility-guided therapy"
              ]
            }
          ]
        },
        {
          "item_title": "Indications for Testing",
          "keywords": ["H. pylori testing", "iron deficiency"],
          "blocks": [
            {
              "block_heading": "Conditions for Testing",
              "block_type": "list",
              "data": [
                "Unexplained iron deficiency",
                "Unexplained skin rashes",
                "Immune Thrombocytopenic Purpura (ITP)",
                "Chronic NSAID use with symptoms"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Irritable Bowel Syndrome (IBS)",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["IBS definition", "functional disorder"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "IBS is a functional gastrointestinal disorder characterized by abdominal pain, constipation, and/or diarrhea."
            }
          ]
        },
        {
          "item_title": "Symptoms",
          "keywords": ["IBS symptoms", "abdominal discomfort"],
          "blocks": [
            {
              "block_heading": "Symptoms",
              "block_type": "list",
              "data": ["Abdominal pain (2-3 times/week)", "Constipation", "Small-volume loose stools (diarrhea)"]
            }
          ]
        },
        {
          "item_title": "Mebeverine",
          "keywords": ["mebeverine", "antispasmodic"],
          "blocks": [
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "135-200 mg orally 2-3 times daily, 30 minutes before meals"
            }
          ]
        },
        {
          "item_title": "Pinaverium",
          "associated_brands": ["Dicetel"],
          "keywords": ["pinaverium", "antispasmodic", "Dicetel"],
          "blocks": [
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "50-100 mg orally 2-3 times daily, 30 minutes before meals, max 300 mg daily"
            },
            {
              "block_heading": "Precautions",
              "block_type": "list",
              "data": ["Do not crush/chew", "Take with water", "Avoid lying down"]
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Dry mouth", "Dizziness", "Headache"]
            }
          ]
        },
        {
          "item_title": "Peppermint Oil",
          "associated_brands": ["Spasmiona"],
          "keywords": ["peppermint oil", "spasm relief", "Spasmiona"],
          "blocks": [
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "1-2 capsules after meals"
            }
          ]
        },
        {
          "item_title": "Constipation Management",
          "keywords": ["IBS constipation", "laxatives"],
          "blocks": [
            {
              "block_heading": "Products",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Bulk-forming laxatives (e.g., Hyfiber)",
                  "children": ["Fiber supplement"]
                },
                {
                  "parent": "Lactulose",
                  "children": ["Preferred for IBS constipation"]
                }
              ]
            },
            {
              "block_heading": "Note",
              "block_type": "text",
              "data": "Stimulant laxatives (e.g., senna, bisacodyl) not recommended."
            }
          ]
        },
        {
          "item_title": "Diarrhea Management",
          "keywords": ["IBS diarrhea", "loperamide"],
          "blocks": [
            {
              "block_heading": "Loperamide",
              "block_type": "text",
              "data": "4 mg initially, then 2 mg after each loose stool"
            }
          ]
        },
        {
          "item_title": "Non-Pharmacological Treatment",
          "keywords": ["probiotics", "low FODMAP", "stress management", "Enterogermina"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Probiotics (e.g., Enterogermina)",
                "Decrease stress and avoid caffeine",
                "Follow a low FODMAP diet",
                "Increase water and fiber intake"
              ]
            }
          ]
        },
        {
          "item_title": "Referral Criteria",
          "keywords": ["IBS referral", "red flags"],
          "blocks": [
            {
              "block_heading": "Symptoms Requiring Referral",
              "block_type": "list",
              "data": ["Unexplained weight loss", "Rectal bleeding", "Iron deficiency anemia"]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Diarrhea",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["diarrhea definition", "loose stools"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Diarrhea is characterized by frequent, loose, or watery stools, often leading to dehydration if untreated."
            }
          ]
        },
        {
          "item_title": "Diosmectite",
          "associated_brands": ["Dioclear"],
          "keywords": ["diosmectite", "mucosal protection", "Dioclear"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Coats and protects gastrointestinal mucosa, adsorbs harmful substances."
            },
            {
              "block_heading": "Dosing",
              "block_type": "list",
              "data": [
                "Adults: 1 sachet 3 times daily",
                "Children 6-18 years: 1 sachet 2-3 times daily",
                "Children 2-6 years: 1 sachet 1-2 times daily"
              ]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "Mix with soft food or 50 mL water."
            },
            {
              "block_heading": "Precautions",
              "block_type": "list",
              "data": [
                "Avoid simultaneous administration with other oral medications",
                "May cause constipation, reduce dose if history of constipation",
                "Not for children under 2 years"
              ]
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Not recommended"
            }
          ]
        },
        {
          "item_title": "Kaolin/Pectin",
          "associated_brands": ["Kapect"],
          "keywords": ["kaolin", "anti-diarrheal", "Kapect"],
          "blocks": [
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "5 mL 3-6 times daily"
            }
          ]
        },
        {
          "item_title": "Oral Rehydration Solution (ORS)",
          "keywords": ["ORS", "rehydration"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Restores or prevents fluid and electrolyte loss."
            },
            {
              "block_heading": "Dosing",
              "block_type": "list",
              "data": [
                "Mild to moderate dehydration: 50-100 mL/kg over 4 hours",
                "Maintenance: 10 mL/kg per loose stool, 2 mL/kg per vomiting episode"
              ]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "Small, frequent amounts, continue breastfeeding/formula."
            }
          ]
        },
        {
          "item_title": "Non-Pharmacological Treatment",
          "keywords": ["BRAT diet", "probiotics", "zinc"],
          "blocks": [
            {
              "block_heading": "Recommendations",
              "block_type": "list",
              "data": [
                "Avoid milk, soda, carbonated, or caffeinated drinks",
                "Take zinc supplements",
                "Probiotics",
                "Follow BRAT diet (Bananas, Rice, Apple, Toast, boiled potatoes)"
              ]
            }
          ]
        },
        {
          "item_title": "Referral Criteria",
          "keywords": ["diarrhea referral", "dehydration signs"],
          "blocks": [
            {
              "block_heading": "Symptoms Requiring Referral",
              "block_type": "list",
              "data": [
                "Fever lasting more than 7 days",
                "Signs of dehydration (dry lips, rapid pulse, sunken eyes, dark urine, dizziness)"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Constipation",
      "items": [
        {
          "item_title": "Definition",
          "keywords": ["constipation types", "painful defecation"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Constipation involves infrequent, painful defecation with dry, hard stools. Acute if less than 3 weeks, chronic if 3 months or more."
            }
          ]
        },
        {
          "item_title": "Stimulant Laxatives",
          "associated_brands": ["Ronzalax", "Sene", "Dulcolax"],
          "keywords": ["stimulant laxatives", "acute constipation", "Ronzalax", "Sene", "Dulcolax"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Preferred for acute constipation."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Senna leaves (e.g., Ronzalax, Sene)", "Bisacodyl (e.g., Dulcolax)"]
            }
          ]
        },
        {
          "item_title": "Bulk-Forming Laxatives",
