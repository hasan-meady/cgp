    {
      "section_title": "Hyperacidity Medications",
      "items": [
        {
          "item_title": "Antacids",
          "associated_brands": ["Tums", "Gaviscon"],
          "keywords": ["antacids", "gastric acid neutralization", "Tums", "Gaviscon"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Neutralize gastric acid for heartburn relief in mild GERD."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Calcium carbonate (e.g., Tums)", "Aluminum hydroxide/magnesium carbonate (e.g., Gaviscon)"]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "After meals and before bed, rapid onset but short duration."
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "May affect absorption of drugs like allopurinol, thyroxine, iron, quinolones, tetracycline; separate administration."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Safe if lifestyle/dietary modifications fail."
            }
          ]
        },
        {
          "item_title": "H2 Blockers",
          "associated_brands": ["Fixit 150", "Famoclar", "Famodar 20"],
          "keywords": ["H2 blockers", "acid suppression", "Fixit", "Famoclar", "Famodar"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Inhibit acid secretion by blocking H2 receptors on parietal cells, used for peptic ulcer, GERD, dyspepsia."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": ["Nizatidine (e.g., Fixit 150)", "Famotidine (e.g., Famoclar, Famodar 20)"]
            },
            {
              "block_heading": "Dosing",
              "block_type": "text",
              "data": "Usually twice daily, max efficacy in 1-3 hours."
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Diarrhea", "Confusion", "Restlessness", "Somnolence", "Headaches", "Dizziness"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Absorption reduced by 10-20% with antacids, unaffected by food."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Safe but second-line if antacids fail."
            }
          ]
        },
        {
          "item_title": "Proton Pump Inhibitors (PPIs) - Hyperacidity",
          "associated_brands": ["Omiz", "Gasec", "Hyposec", "Gastrazole", "Nexium", "Esomep", "Esopole", "Peptazole", "Lanzor", "Pantazol", "Pantoloc", "Pantomax", "Toprazole", "Dexilant", "Pariet"],
          "keywords": ["PPIs", "acid secretion inhibition", "Omiz", "Gasec", "Nexium", "Esomep", "Peptazole", "Lanzor", "Pantazol", "Pantoloc", "Dexilant", "Pariet"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Block acid secretion by inhibiting H+/K+-ATPase, used for GERD, dyspepsia, ulcers, H. pylori, esophagitis."
            },
            {
              "block_heading": "Products",
              "block_type": "list",
              "data": [
                "Omeprazole (e.g., Omiz, Gasec)",
                "Esomeprazole (e.g., Nexium, Esomep)",
                "Lansoprazole (e.g., Peptazole, Lanzor)",
                "Pantoprazole (e.g., Pantazol, Pantoloc)",
                "Dexlansoprazole (e.g., Dexilant)",
                "Rabeprazole (e.g., Pariet)"
              ]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "30-60 minutes before breakfast, second dose before evening meal if needed. Dexilant can be taken with/without food."
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": ["Enteric infections (e.g., Clostridioides difficile)", "Malabsorption (magnesium, calcium, iron, vitamin B12)"]
            },
            {
              "block_heading": "Drug Interactions",
              "block_type": "list",
              "data": ["Omeprazole/esomeprazole reduce Clopidogrel's antiplatelet effect", "Interact with warfarin, phenytoin, itraconazole"]
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Not concomitant with H2 blockers; H2 blockers can be taken before bedtime."
            },
            {
              "block_heading": "Pregnancy",
              "block_type": "text",
              "data": "Safe if antacids/H2 blockers fail; Omeprazole, Lansoprazole, Pantoprazole most studied."
            }
          ]
        }
      ]
    },
    {
      "section_title": "Case Studies",
      "items": [
        {
          "item_title": "Case 1: Acute Constipation",
          "keywords": ["acute constipation", "laxatives", "fiber", "Ronzalax", "Sene", "Dulcolax", "Agiolax", "Ezilax", "Duphalac", "Movicol"],
