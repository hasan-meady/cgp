            {
              "block_heading": "Pharmacological Treatment",
              "block_type": "list",
              "data": ["Diosmectite (Dioclear): 1 sachet 2-3 times daily", "Kaolin/Pectin (Kapect): 5 mL 3-6 times daily", "ORS to prevent dehydration"]
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "list",
              "data": ["Avoid milk, soda, carbonated/caffeinated drinks", "Zinc supplements", "Probiotics", "BRAT diet (Bananas, Rice, Apple, Toast, boiled potatoes)"]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": ["Fever lasting more than 7 days", "Dehydration signs (dry lips, rapid pulse, sunken eyes, dark urine, dizziness)"]
            }
          ]
        },
        {
          "item_title": "Case 3: Irritable Bowel Syndrome",
          "keywords": ["IBS treatment", "antispasmodics", "low FODMAP", "Mebeverine", "Pinaverium", "Spasmiona", "Hyfiber", "Lactulose", "Loperamide", "Enterogermina"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "45-year-old male with occasional lower abdominal pain (2-3 times/week), constipation, and small-volume loose stools, seeking relief."
            },
            {
              "block_heading": "Assessment",
              "block_type": "text",
              "data": "Symptoms suggest IBS"
            },
            {
              "block_heading": "Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "Antispasmodics: Mebeverine (135-200 mg 2-3 times daily), Pinaverium (50-100 mg 2-3 times daily)",
                "Peppermint oil (Spasmiona): 1-2 capsules after meals",
                "Constipation: Bulk-forming laxatives (Hyfiber), Lactulose",
                "Diarrhea: Loperamide (4 mg initially, 2 mg per loose stool)"
              ]
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "list",
              "data": ["Probiotics (Enterogermina)", "Decrease stress, avoid caffeine", "Low FODMAP diet", "Increase water/fiber intake"]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": ["Unexplained weight loss", "Rectal bleeding", "Iron deficiency anemia"]
            }
          ]
        },
        {
          "item_title": "Case 4: GERD",
          "keywords": ["GERD management", "PPIs", "lifestyle changes", "Omeprazole", "Esomeprazole", "Pantoprazole", "Nizatidine", "Famotidine", "Tums", "Gaviscon", "Enterogermina"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "50-year-old obese male, smoker, with heartburn, bitter taste, regurgitation, dry cough, and high caffeine intake."
            },
            {
              "block_heading": "Assessment",
              "block_type": "text",
              "data": "Symptoms indicate GERD"
            },
            {
              "block_heading": "Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "PPIs (first-line): Omeprazole, Esomeprazole, Pantoprazole (30-60 min before breakfast)",
                "H2 blockers (second-line): Nizatidine, Famotidine (before bedtime, separate from PPIs)",
                "Antacids: Calcium carbonate (Tums), Aluminum hydroxide/magnesium carbonate (Gaviscon) after meals"
              ]
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "Minimize caffeine, quit smoking, lose weight",
                "Wear loose clothing",
                "Avoid lying down after meals",
                "Sleep with head/shoulders propped up",
                "Avoid fatty, fried foods, hot sauce, garlic, onion",
                "Supplements: Manuka honey, Probiotics (Enterogermina)"
              ]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": [
                "Nausea, bloody vomit, black/tarry stools",
                "Dysphagia, anemia, unexplained weight loss",
                "Burping, skin rashes, stomach pain without food (test for H. pylori)"
              ]
            }
          ]
        },
        {
          "item_title": "Case 5: Pediatric Vomiting",
          "keywords": ["pediatric vomiting", "ondansetron", "rehydration", "ORS", "Bablyte", "Kromafina", "Dompy", "Motilium"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "8-year-old child with vomiting 3-4 times daily, no diarrhea or fever, seeking anti-vomiting medication."
            },
            {
              "block_heading": "Assessment",
              "block_type": "text",
              "data": "Non-emergency vomiting, check for food poisoning"
            },
            {
              "block_heading": "Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "Oral electrolytes: ORS sachets, Bablyte",
                "Ondansetron (Kromafina syrup): 0.1-0.2 mg/kg/dose 3-4 times",
                "Domperidone (Dompy syrup, Motilium syrup): 10 mL 3 times daily, 30 min before meals"
              ]
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "Drink clear/ice-cold drinks",
                "Avoid fried, greasy, sweet foods",
                "Eat light, bland foods (saltine crackers, plain bread)",
                "Eat slowly, smaller frequent meals",
                "Avoid activity after eating"
              ]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": ["Bloody vomit, stiff neck, lethargy, confusion", "Rapid breathing, severe abdominal pain, severe headache", "Dehydration signs"]
            }
          ]
        }
      ]
    }
