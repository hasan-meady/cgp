            {
              "block_heading": "Pharmacological Treatment",
              "block_type": "list",
              "data": [
                "Stimulant laxatives: Senna (Ronzalax, Sene), Bisacodyl (Dulcolax)",
                "Bulk-forming laxative: Agiolax granules (1-2 tsp 2-4 times daily with water)",
                "Osmotic laxatives: Lactulose (Ezilax, Duphalac), Polyethylene glycol (Movicol)",
                "Enemas for severe cases"
              ]
            },
            {
              "block_heading": "Non-Pharmacological Treatment",
              "block_type": "list",
              "data": ["Drink plenty of water", "Regular exercise", "Avoid ignoring urge to pass stool", "Increase fiber intake", "Prebiotics/probiotics"]
            },
            {
              "block_heading": "Referral Criteria",
              "block_type": "list",
              "data": ["Rectal bleeding", "Complete stool blockage"]
            }
          ]
        },
        {
          "item_title": "Case 2: Pediatric Diarrhea",
          "keywords": ["pediatric diarrhea", "ORS", "BRAT diet", "Dioclear", "Kapect"],
          "blocks": [
            {
              "block_heading": "Patient Presentation",
              "block_type": "text",
              "data": "10-year-old child with watery diarrhea for 5 days, seeking medication to stop diarrhea."
            },
            {
              "block_heading": "Assessment",
              "block_type": "text",
              "data": "Acute diarrhea (less than 14 days)"
