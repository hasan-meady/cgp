              "data": ["losartan, valsartan, irbesartan, candesartan, olmesartan"]
            },
            {
              "block_heading": "Brand Names",
              "block_type": "list",
              "data": ["diovan, lotevan, cozaar, atacand"]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "Once daily at the same time each day"
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": [
                "May increase potassium levels",
                "Allergic reactions (hives, swelling, breathing difficulty)"
              ]
            },
            {
              "block_heading": "Emergency",
              "block_type": "text",
              "data": "Get emergency medical help if allergic reaction: hives, difficulty breathing, or swelling of face, lips, tongue, and/or throat"
            },
            {
              "block_heading": "Contraindications",
              "block_type": "text",
              "data": "Contraindicated in pregnancy due to birth defects"
            },
            {
              "block_heading": "Monitoring",
              "block_type": "text",
              "data": "Monitor potassium levels frequently"
            }
          ]
        },
        {
          "item_title": "Calcium Channel Blockers (CCBs) - Dihydropyridines",
          "associated_brands": ["amlor", "amvasc", "amlopine", "norvasc"],
          "keywords": ["calcium channel blockers", "hypertension treatment", "cardiovascular drugs", "amlodipine", "amlor", "vascodipine", "amvasc", "lotense", "lodipam", "side effects of calcium channel blockers"],
          "blocks": [
            {
              "block_heading": "Examples",
              "block_type": "list",
              "data": ["amlodipine"]
            },
            {
              "block_heading": "Brand Names",
              "block_type": "list",
              "data": ["amlor, amvasc, amlopine"]
            },
            {
              "block_heading": "Indications",
              "block_type": "text",
              "data": "Preferred for hypertension"
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "Once daily at the same time each day"
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": [
                "Ankle swelling",
                "Tiredness",
                "Dizziness",
                "Headache",
                "Facial warmth",
                "Palpitations"
              ]
            },
            {
              "block_heading": "Management",
              "block_type": "text",
              "data": "Elevate legs to manage ankle swelling"
            }
          ]
        },
        {
          "item_title": "Calcium Channel Blockers (CCBs) - Non-Dihydropyridines",
          "keywords": ["calcium channel blockers", "hypertension treatment", "cardiovascular drugs", "diltiazem", "verapamil", "side effects of calcium channel blockers"],
          "blocks": [
            {
              "block_heading": "Examples",
              "block_type": "list",
              "data": ["verapamil, diltiazem"]
            },
            {
              "block_heading": "Indications",
              "block_type": "text",
              "data": "Affect heart rate"
            },
            {
              "block_heading": "Precautions",
              "block_type": "text",
              "data": "Use cautiously with heart conditions"
            }
          ]
        },
        {
          "item_title": "Beta-Blockers",
          "associated_brands": ["concor", "cardicor", "normoten", "tenormin", "ravildo", "monocor", "coreg", "lopresor", "nebilet"],
          "keywords": ["Concor", "beta-blockers", "hypertension medication", "cardiovascular drugs", "atenolol", "bisoprolol", "carvedilol", "metoprolol", "nebivolol", "tenormin", "ravildo", "monocor", "coreg", "lopresor", "nebilet", "side effects of beta-blockers"],
          "blocks": [
            {
              "block_heading": "Examples",
              "block_type": "list",
              "data": ["atenolol, bisoprolol, carvedilol, metoprolol, nebivolol"]
            },
            {
              "block_heading": "Brand Names",
              "block_type": "list",
              "data": ["concor, cardicor, normoten, tenormin, ravildo, monocor, coreg, lopresor, nebilet"]
            },
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": [
                "Once daily at the same time each day",
                "Carvedilol and metoprolol should be taken with or immediately after meals"
              ]
            },
            {
              "block_heading": "Precautions",
              "block_type": "list",
              "data": [
                "Avoid sudden discontinuation to prevent rebound hypertension",
                "Use cautiously in asthma/COPD (prefer selective types like atenolol, nebivolol, bisoprolol; avoid non-selective)",
                "For diabetic patients: β-blockers can mask symptoms of hypoglycemia"
              ]
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": [
                "May mask hypoglycemia symptoms in diabetics",
                "May cause erectile dysfunction (nebivolol as alternative)",
                "Dizziness",
                "Fatigue"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "General Points",
      "items": [
        {
          "item_title": "General Considerations",
          "keywords": [
            "pregnancy-safe drugs", "methyldopa", "aldomet", "hydralazine", "labetalol", "trandate",
            "atenolol", "tenormin", "nebivolol", "bivoneb", "bisoprolol", "concor",
            "spironolactone", "aldactone", "lisinopril", "amlodipine", "amlor", "vascodipine",
            "pseudoephedrine", "tenoryl", "coversyl", "beta-blockers", "ACE inhibitors",
            "CCBs", "NSAIDs", "decongestants", "side effects of ACE inhibitors",
            "side effects of beta-blockers", "side effects of calcium channel blockers",
            "side effects of spironolactone", "amvasc", "lotense", "lodipam",
            "side effects of hydralazine", "side effects of labetalol", "side effects of methyldopa",
            "side effects of atenolol", "side effects of bisoprolol", "side effects of nebivolol",
            "side effects of carvedilol", "side effects of metoprolol", "side effects of propranolol"
          ],
          "blocks": [
            {
              "block_heading": "General Considerations",
              "block_type": "list",
              "data": [
                "Pregnancy-safe medications include Methyldopa (Aldomet), Hydralazine, Labetalol (Trandate)",
                "Selective β-blockers (Atenolol [Tenormin], Nebivolol [Nebilet], Bisoprolol [Concor]) used cautiously in asthma/COPD, non-selective to be avoided",
                "β-blockers (concor) may cause erectile dysfunction (Nebivolol [Nebilet] as alternative)",
                "ACEIs (e.g., Lisinopril [Zestril], Enalapril [Enapren]) and Spironolactone [Aldactone] increase potassium",
                "ACEIs (coversyl, tenoryl) cause dry cough and angioedema",
                "CCBs (e.g., Amlodipine [Amlor, vascodipine, Norvasc], Nifedipine [Adalat]) may cause foot edema",
                "NSAIDs (e.g., Ibuprofen [Brufen]) reduce the effect of hypertension drugs",
                "Decongestants like pseudoephedrine [flutab, panadol cold & flu] raise BP",
                "β-blockers (e.g., Propranolol [Inderal]) mask hypoglycemia symptoms"
              ]
            }
          ]
        }
      ]
    },
