  "sections": [
    {
      "section_title": "Hypertension Classification",
      "items": [
        {
          "item_title": "Classification",
          "keywords": ["hypertension classification", "blood pressure ranges"],
          "blocks": [
            {
              "block_heading": "Blood Pressure Categories",
              "block_type": "list",
              "data": [
                "Normotensive: <120/80",
                "Elevated: 120–129/<80",
                "Stage I: 130–139/80–89",
                "Stage II: ≥140/90",
                "Stage determined by worse value",
                "BP goal: <130/80 for all patients"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Risk Factors",
      "items": [
        {
          "item_title": "Risk Factors",
          "keywords": ["hypertension risks", "cardiovascular risk factors"],
          "blocks": [
            {
              "block_heading": "Risk Factors",
              "block_type": "list",
              "data": [
                "Obesity, diabetes mellitus, dyslipidemia, alcohol intake, smoking, family history of hypertension or chronic coronary disease",
                "Sodium intake >1.5 g/day",
                "Age >60 years",
                "Low fruit and vegetable intake",
                "Aerobic exercise <3 times/week",
                "Metabolic syndrome, sleep apnea"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Lifestyle Modifications",
      "items": [
        {
          "item_title": "Weight Management",
          "keywords": ["weight management", "hypertension prevention"],
          "blocks": [
            {
              "block_heading": "Weight Management",
              "block_type": "text",
              "data": "Achieve BMI ~25, waist circumference <102 cm (men) or <88 cm (women)"
            }
          ]
        },
        {
          "item_title": "Dietary Recommendations",
          "keywords": ["dietary recommendations", "hypertension prevention", "nutrition"],
          "blocks": [
            {
              "block_heading": "Dietary Recommendations",
              "block_type": "list",
              "data": [
                "Follow a healthy diet rich in fruits, vegetables, and low-fat dairy",
                "Reduce sodium to <1500 mg/day",
                "Increase potassium to 3500–5000 mg/day"
              ]
            }
          ]
        },
        {
          "item_title": "Physical Activity",
          "keywords": ["physical activity", "hypertension prevention", "exercise"],
          "blocks": [
            {
              "block_heading": "Physical Activity",
              "block_type": "text",
              "data": "Engage in 30 minutes of moderate-intensity physical activity"
            }
          ]
        }
      ]
    },
    {
      "section_title": "Follow Up and Patient Adherence",
      "items": [
        {
          "item_title": "Adherence Strategies",
          "keywords": ["patient follow-up", "medication adherence"],
          "blocks": [
            {
              "block_heading": "Adherence Strategies",
              "block_type": "list",
              "data": [
                "Simplify medication regimens with less frequent dosing or combinations",
                "Foster a blame-free environment to encourage adherence"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Blood Pressure Measurement",
      "items": [
        {
          "item_title": "Measurement Guidelines",
          "keywords": ["blood pressure monitoring", "diagnostic procedures"],
          "blocks": [
            {
              "block_heading": "Measurement Guidelines",
              "block_type": "list",
              "data": [
                "Use a calibrated device with suitable cuff size",
                "Avoid smoking, caffeine, stress, or exercise 30 minutes prior",
                "Sit quietly for 5 minutes with arm at heart level and empty bladder",
                "Take three readings 1–2 minutes apart and average them",
                "Confirm diagnosis with measurements on three separate occasions"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Anti-Hypertensive Medications",
      "items": [
        {
          "item_title": "Diuretics",
          "keywords": ["diuretics", "hypokalemia", "hyperuricemia", "electrolyte monitoring", "blood sugar", "side effects of diuretics"],
          "blocks": [
            {
              "block_heading": "Administration",
              "block_type": "list",
              "data": [
                "Administer low doses to minimize side effects",
                "Second dose should not be taken later than 4 P.M. to avoid nighttime urination"
              ]
            },
            {
              "block_heading": "Dietary Considerations",
              "block_type": "list",
              "data": [
                "Monitor electrolytes and blood sugar regularly",
                "May raise blood sugar; monitor more frequently"
              ]
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": [
                "May cause hypokalemia (requires potassium supplements to ensure enough potassium for heart)",
                "May cause hyperuricemia (may worsen gout)",
                "Increased urination (patient may urinate more throughout the day)",
                "Dizziness when standing"
              ]
            },
            {
              "block_heading": "Management",
              "block_type": "text",
              "data": "Advise patient to get up slowly and let feet hang over the bed for a few minutes before getting up to avoid dizziness"
            }
          ]
        },
        {
          "item_title": "ACE Inhibitors (ACEIs)",
          "associated_brands": ["coversyl", "tenoryl", "vasotec", "zestril", "accupril"],
          "keywords": ["ACEIs", "hypertension treatment", "cardiovascular drugs", "lisinopril", "ramipril", "enalapril", "perindopril", "quinapril", "coversyl", "tenoryl", "vasotec", "zestril", "accupril", "side effects of ACE inhibitors"],
          "blocks": [
            {
              "block_heading": "Examples",
              "block_type": "list",
              "data": ["lisinopril, ramipril, enalapril, perindopril, quinapril"]
            },
            {
              "block_heading": "Brand Names",
              "block_type": "list",
              "data": ["coversyl, tenoryl, vasotec, zestril, accupril"]
            },
            {
              "block_heading": "Administration",
              "block_type": "text",
              "data": "Once daily at the same time each day"
            },
            {
              "block_heading": "Indications",
              "block_type": "text",
              "data": "Effective for diabetes and heart failure (especially good for these conditions)"
            },
            {
              "block_heading": "Side Effects",
              "block_type": "list",
              "data": [
                "May cause dry cough (switch to ARB if it occurs)",
                "Elevated potassium",
                "Allergic reactions (hives, swelling, breathing difficulty)"
              ]
            },
            {
              "block_heading": "Emergency",
              "block_type": "text",
              "data": "Get emergency medical help if allergic reaction: hives, difficulty breathing, or swelling of face, lips, tongue, and/or throat"
            },
            {
              "block_heading": "Contraindications",
              "block_type": "text",
              "data": "Contraindicated in pregnancy due to birth defects"
            },
            {
              "block_heading": "Monitoring",
              "block_type": "text",
              "data": "Monitor potassium levels frequently"
            }
          ]
        },
        {
          "item_title": "Angiotensin Receptor Blockers (ARBs)",
          "associated_brands": ["diovan", "lotevan", "cozaar", "atacand"],
          "keywords": ["ARBs", "hypertension medication", "angiotensin blockers", "losartan", "valsartan", "irbesartan", "candesartan", "olmesartan", "cozaar", "diovan", "avapro", "atacand", "benicar", "side effects of ARBs"],
          "blocks": [
            {
              "block_heading": "Examples",
