  "sections": [
    {
      "section_title": "Hair Structure",
      "items": [
        {
          "item_title": "Hair Structure",
          "keywords": ["hair structure", "keratin", "hair shaft", "medulla", "cortex", "cuticle", "dermal papilla", "sebaceous glands"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Hair is made from strong structural protein named as Keratin. The nail and outer skin layer comprised of the same protein."
            },
            {
              "block_heading": "Hair Shaft Layers",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Medulla",
                  "children": ["Innermost layer, only present in large thick hairs."]
                },
                {
                  "parent": "Cortex",
                  "children": ["Middle layer that gives hair its strength, texture & color."]
                },
                {
                  "parent": "Cuticle",
                  "children": ["Outermost thin and colorless layer that prevents damage and controls water content."]
                }
              ]
            },
            {
              "block_heading": "Dermal Papilla",
              "block_type": "text",
              "data": "Contains blood supply and nerves that produce nutrients for hair growth."
            },
            {
              "block_heading": "Sebaceous Glands",
              "block_type": "text",
              "data": "Secretes sebum, an oily substance that lubricates the hair."
            }
          ]
        }
      ]
    },
    {
      "section_title": "Hair Growth Cycle",
      "items": [
        {
          "item_title": "Hair Growth Cycle",
          "keywords": ["hair growth cycle", "hair phases", "anagen", "catagen", "telogen", "exogen", "stages of hair growth"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "The hair growth cycle consists of distinct phases that regulate hair growth and shedding."
            },
            {
              "block_heading": "Anagen",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Duration",
                  "children": ["2-8 years"]
                },
                {
                  "parent": "Description",
                  "children": ["Active growth phase where about 1 cm of hair grows every 28 days. 90% of hairs are in this phase."]
                }
              ]
            },
            {
              "block_heading": "Catagen",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Duration",
                  "children": ["4-6 weeks"]
                },
                {
                  "parent": "Description",
                  "children": ["Transition phase where hair growth stops."]
                }
              ]
            },
            {
              "block_heading": "Telogen",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Duration",
                  "children": ["2-3 months"]
                },
                {
                  "parent": "Description",
                  "children": ["Resting phase where hairs don't grow but don't usually fall out."]
                }
              ]
            },
            {
              "block_heading": "Exogen",
              "block_type": "nested_list",
              "data": [
                {
                  "parent": "Description",
                  "children": ["Shedding phase where up to 100 hairs per day may be lost normally."]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Nutrients for Healthy Hair",
      "items": [
        {
          "item_title": "Nutrients for Healthy Hair",
          "keywords": [
            "nutrients for hair", "hair vitamins", "essential nutrients for hair", "hair protein", "keratin production",
            "protein for hair growth", "biotin", "vitamin B7", "hair growth", "biotin benefits for hair",
            "iron", "ferritin", "hair oxygen", "iron deficiency hair loss",
            "omega 3", "hair hydration", "scalp health", "omega 3 benefits for hair",
            "water", "hair moisture", "hydration for hair",
            "B vitamins", "B6", "B12", "folate", "B vitamins for hair",
            "vitamin C", "collagen", "iron absorption", "vitamin C for hair",
            "zinc", "hair strength", "oil glands", "zinc deficiency hair loss",
            "L-cystine", "amino acids", "hair bonds", "cystine benefits for hair"
          ],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Essential nutrients support healthy hair growth and maintenance."
            },
            {
              "block_heading": "Protein",
              "block_type": "text",
              "data": "Forms keratin, the structural protein of hair. Low intake slows growth and weakens hair."
            },
            {
              "block_heading": "Biotin",
              "block_type": "text",
              "data": "Promotes hair growth by helping produce amino acids that form proteins."
            },
            {
              "block_heading": "Iron",
              "block_type": "text",
              "data": "Provides oxygen to hair follicles via red blood cells. Low ferritin can affect hair."
            },
            {
              "block_heading": "Omega-3 Fatty Acids",
              "block_type": "text",
              "data": "Prevents inflammation, promotes circulation, and maintains scalp/hair hydration."
            },
            {
              "block_heading": "Water",
              "block_type": "text",
              "data": "Maintains moisture to prevent dryness and breakage."
            },
            {
              "block_heading": "B Vitamins",
              "block_type": "text",
              "data": "Help create red blood cells that carry nutrients to scalp and follicles."
            },
            {
              "block_heading": "Vitamin C",
              "block_type": "text",
              "data": "Helps absorb iron and forms collagen needed for hair follicles."
            },
            {
              "block_heading": "Zinc",
              "block_type": "text",
              "data": "Strengthens follicles, prevents loss, and maintains oil gland function."
            },
            {
              "block_heading": "L-Cystine",
              "block_type": "text",
              "data": "Forms disulfide bonds that maintain hair texture, thickness and moisture."
            }
          ]
        }
      ]
    },
    {
      "section_title": "Hair Coloring Dyes",
      "items": [
        {
          "item_title": "Permanent Hair Dye",
          "keywords": ["hair dye types", "types of hair coloring", "hair coloring options", "permanent dye"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Stays forever, works by oxidation. Contains PPD, hydrogen peroxide (6%), ammonia, and couplers."
            },
            {
              "block_heading": "Process",
              "block_type": "list",
              "data": [
                "Removes natural color",
                "Applies new color"
              ]
            },
            {
              "block_heading": "Duration",
              "block_type": "text",
              "data": "6-8 weeks"
            },
            {
              "block_heading": "Risks",
              "block_type": "list",
              "data": [
                "PPD can cause allergic reactions",
                "Damages hair structure"
              ]
            }
          ]
        },
        {
          "item_title": "Demi-permanent Hair Dye",
          "keywords": ["hair dye types", "types of hair coloring", "demi-permanent"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Milder, ammonia-free with 2% hydrogen peroxide. Deposits color on cuticle and penetrates cortex but can't bleach."
            },
            {
              "block_heading": "Duration",
              "block_type": "text",
              "data": "12-24 shampoos"
            },
            {
              "block_heading": "Benefits",
              "block_type": "list",
              "data": [
                "Gentler",
                "Less damaging",
                "Good for fragile hair covering grays"
              ]
            }
          ]
        },
        {
          "item_title": "Semi-permanent Hair Dye",
          "keywords": ["hair dye types", "types of hair coloring", "semi-permanent"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "No ammonia or peroxide. Deposits color only on cuticle. Can be synthetic or natural."
            },
            {
              "block_heading": "Coverage",
              "block_type": "text",
              "data": "Blends up to 30% grays"
            },
            {
              "block_heading": "Duration",
              "block_type": "text",
              "data": "4-8 shampoos"
            },
            {
              "block_heading": "Benefits",
              "block_type": "list",
              "data": [
                "No PPD",
                "Rarely causes allergies",
                "No patch test needed"
              ]
            }
          ]
        },
        {
          "item_title": "Gradual Hair Dye",
          "keywords": ["hair dye types", "types of hair coloring", "gradual dye"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Metallic solutions that darken hair gradually over repeated applications."
            },
            {
              "block_heading": "Characteristics",
              "block_type": "list",
              "data": [
                "Fades with shampooing",
                "No perming/straightening after use",
                "No PPD",
                "No patch test needed"
              ]
            }
          ]
        },
        {
          "item_title": "Temporary Hair Dye",
          "keywords": ["hair dye types", "types of hair coloring", "temporary dye"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Large molecules that sit on hair surface without penetrating."
            },
            {
              "block_heading": "Duration",
              "block_type": "text",
              "data": "1 shampoo (may last longer on porous hair)"
            },
            {
              "block_heading": "Uses",
              "block_type": "list",
              "data": [
                "Brightens original shade",
                "Adds tint to dyed hair"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Side Effects of Hair Dyes",
      "items": [
        {
          "item_title": "Side Effects of Hair Dyes",
          "keywords": ["side effects of hair dyes", "hair damage from dye", "dye allergies", "scalp irritation from dye", "risks of hair coloring"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Hair dyes can cause various adverse effects on hair and scalp."
            },
            {
              "block_heading": "Effects",
              "block_type": "list",
              "data": [
                "Loss of hair strength",
                "Reduced heat styling tolerance",
                "Decreased hair thickness",
                "Follicle damage leading to hair loss",
                "Excessive dryness",
                "Permanently enlarged pores",
                "Skin irritation"
              ]
            }
          ]
        }
      ]
    },
    {
      "section_title": "Ammonia in Hair Color",
      "items": [
        {
          "item_title": "Ammonia in Hair Color",
          "keywords": ["ammonia in hair dye", "risks of ammonia in dye", "ammonia-free alternatives", "side effects of ammonia in hair color"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "Ammonia is used in hair dyes to facilitate color deposition but has potential risks."
            },
            {
              "block_heading": "Function",
              "block_type": "text",
              "data": "Alkali that opens cuticles to allow dye deposition on cortex."
            },
            {
              "block_heading": "Risks",
              "block_type": "list",
              "data": [
                "Forms irritating ammonium hydroxide",
                "Damages cuticle leading to dry, brittle hair",
                "Vapors can cause lung/sinus/throat/eye issues",
                "Destroys tyrosine (melanin regulator)",
                "Pungent odor from quick evaporation"
              ]
            },
            {
              "block_heading": "Solution",
              "block_type": "text",
              "data": "Ammonia-free dyes (modern formulas are equally effective but less damaging)"
            }
          ]
        }
      ]
    },
