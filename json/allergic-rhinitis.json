      "section_title": "Non-Pharmacologic Management",
      "items": [
        {
          "item_title": "Management of Rhinitis",
          "keywords": [
            "non pharmacologic management allergic rhinitis",
            "allergy prevention",
            "pollen avoidance",
            "pollen removal",
            "dust mite control",
            "dust mite prevention",
            "humidity control",
            "pet allergy prevention",
            "cat allergen reduction",
            "occupational allergen protection"
          ],
          "blocks": [
            {
              "block_heading": "Non-Pharmacologic Strategies",
              "block_type": "list",
              "data": [
                "Keep windows and doors of house and car closed during pollen season (use air conditioning on recirculating mode if necessary)",
                "Shower after outdoor exposure to remove pollen from hair and skin",
                "Use impermeable mattress and pillow covers to reduce dust mite exposure",
                "Wash bed linens every 2 weeks in hot water (≥130°F) to kill dust mites",
                "Maintain indoor humidity below 50% using dehumidification or air conditioning",
                "For animal allergy: complete avoidance or confine animal to non-carpeted areas and keep out of bedroom",
                "Reduce cat allergen levels with filters and by bathing the cat weekly",
                "Use facial masks for occupational allergens"
              ]
            }
          ]
        }
      ]
    },
