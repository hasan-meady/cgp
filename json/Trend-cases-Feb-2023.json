        {
          "item_title": "Overview",
          "keywords": ["digestive health", "GI system", "digestive system", "nutrient absorption", "detoxification"],
          "blocks": [
            {
              "block_heading": "Description",
              "block_type": "text",
              "data": "The gastrointestinal (GI) system is responsible for nutrient intake and exit, energy production, blood flow, nerve signaling, hormone control, metabolic reactions, and detoxification."
